/**app.wxss - Ins 极简风电子衣柜（莫兰迪低饱和色系）**/

page {
  /* ===== Ins 极简风 · 莫兰迪色系 ===== */
  /* 主色：低饱和奶咖 */
  --color-primary: #C4A882;
  --color-primary-light: #D9C4A8;
  --color-primary-deep: #A68B6A;
  --color-primary-gradient: linear-gradient(135deg, #D9C4A8, #C4A882);

  /* 背景：浅米白 → 纯白，干净通透 */
  --bg-start: #FAFAF8;
  --bg-end: #FFFFFF;
  --bg-page: #FAFAF8;

  /* 卡片：纯白 + 极淡灰边框，无阴影 */
  --card-bg: #FFFFFF;
  --card-border: rgba(0, 0, 0, 0.06);
  --card-bg-strong: #FFFFFF;
  --card-bg-solid: #FFFFFF;

  /* 表面层级：极简 */
  --surface-elevated: #FFFFFF;
  --surface-inner: #F7F5F2;
  --stats-bg: #FFFFFF;
  --ai-card-bg: #F5F0EB;
  --ai-card-border: rgba(0, 0, 0, 0.06);
  --ai-halo: transparent;

  /* 图标：浅灰线条 */
  --icon-stroke: #B8B0A8;
  --icon-stroke-soft: rgba(184, 176, 168, 0.50);
  --icon-fill: transparent;

  /* 阴影：极简，几乎无阴影 */
  --shadow-soft: none;
  --shadow-card: none;
  --shadow-hover: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  --shadow-ios: none;

  /* 文字：深灰，非纯黑，低饱和 */
  --text-main: #3D3D3D;
  --text-sub: #9E9E9E;
  --text-assist: #BDBDBD;

  --nav-bg: rgba(250, 250, 248, 0.95);
  --line-soft: rgba(0, 0, 0, 0.06);
  --line-grid: #F0EEEC;

  /* ===== 极简场景 Token（去玻璃态） ===== */
  --scene-wall-top: #F5F0EB;
  --scene-wall-bottom: #EDE8E2;
  --scene-floor-top: #E8E2DA;
  --scene-floor-bottom: #E0DAD2;
  --scene-skirting: rgba(180, 170, 158, 0.25);
  --glass-panel: #F7F5F2;
  --glass-edge: rgba(0, 0, 0, 0.08);
  --glass-outline: rgba(180, 170, 158, 0.35);
  --led-glow: transparent;
  --led-line: transparent;
  --bridge-top: #F5F0EB;

  /* 圆角：极简小圆角 */
  --radius-xs: 8rpx;
  --radius-sm: 12rpx;
  --radius-tag: 12rpx;
  --radius-card: 16rpx;
  --radius-card-lg: 20rpx;
  --radius-btn: 9999rpx;

  background: var(--bg-page);
  min-height: 100vh;
  /* 极简无衬线细字体 */
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", "HarmonyOS Sans SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
  color: var(--text-main);
  font-size: 28rpx;
  line-height: 1.5;
  letter-spacing: 0.3rpx;
  -webkit-font-smoothing: antialiased;
}

/* 字体工具类（统一无衬线，保留 class 名向后兼容） */
.font-serif { font-family: inherit; font-weight: 600; letter-spacing: 1rpx; }
.font-sans  { font-family: inherit; }

/* ===== 深色主题（Ins 极简暗色模式） ===== */
.theme-dark {
  /* 背景：深灰，非纯黑 */
  --bg-start: #1A1A1A;
  --bg-end:   #1A1A1A;
  --bg-page:  #1A1A1A;

  /* 主色：暗色下 muted */
  --color-primary:       #A68B6A;
  --color-primary-light: #B8A08A;
  --color-primary-deep:  #8A7358;
  --color-primary-gradient: linear-gradient(135deg, #B8A08A, #A68B6A);

  /* 卡片：深灰 */
  --card-bg:          #242424;
  --card-bg-strong:   #2A2A2A;
  --card-bg-solid:    #1E1E1E;
  --card-border:      rgba(255, 255, 255, 0.06);

  --surface-elevated: #242424;
  --surface-inner:    #2A2A2A;
  --stats-bg:         #242424;
  --ai-card-bg:       #2A2A2A;
  --ai-card-border:   rgba(255, 255, 255, 0.06);
  --ai-halo:          transparent;

  /* 图标：浅灰 */
  --icon-stroke:      #888888;
  --icon-stroke-soft: rgba(136, 136, 136, 0.50);
  --icon-fill:        transparent;

  /* 阴影：极简 */
  --shadow-soft:  none;
  --shadow-card:  none;
  --shadow-hover: 0 8rpx 24rpx rgba(0, 0, 0, 0.20);
  --shadow-ios: none;

  /* 文字：浅灰 */
  --text-main:   #E8E8E8;
  --text-sub:    #888888;
  --text-assist: #666666;

  --nav-bg:   rgba(26, 26, 26, 0.95);
  --line-soft: rgba(255, 255, 255, 0.06);
  --line-grid: rgba(255, 255, 255, 0.04);

  /* 场景盒 - 深色极简 */
  --scene-wall-top:    #242424;
  --scene-wall-bottom: #1E1E1E;
  --scene-floor-top:   #1E1E1E;
  --scene-floor-bottom:#1A1A1A;
  --scene-skirting:    rgba(136, 136, 136, 0.15);
  --glass-panel:       #2A2A2A;
  --glass-edge:        rgba(255, 255, 255, 0.08);
  --glass-outline:     rgba(136, 136, 136, 0.25);
  --led-glow:          transparent;
  --led-line:          transparent;
  --bridge-top:        #242424;

  background: var(--bg-page);
  color: var(--text-main);
}

/* 通用容器 */
.container {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  width: 100%;
}

/* 玻璃态卡片 - Virtual Wardrobe */
.glass-card {
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  box-shadow: var(--shadow-soft);
  border-radius: var(--radius-card);
  box-sizing: border-box;
}

/* 主按钮 - 焦糖色实心 + 大圆角 + 柔和投影 */
.btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 48rpx;
  background: var(--color-primary);
  color: #FFFFFF;
  border-radius: var(--radius-btn);
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 16rpx -4rpx rgba(212, 163, 115, 0.40);
  transition: transform 0.15s ease;
}

/* 次级按钮 - 玻璃态 */
.btn-ghost {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 48rpx;
  background: var(--card-bg);
  color: var(--color-primary);
  border: 1rpx solid var(--card-border);
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: var(--shadow-soft);
}

/* 按压反馈 */
.tap-scale {
  transition: transform 0.15s ease;
}
.tap-scale:active {
  transform: scale(0.97);
}

/* 文字层级工具类 */
.text-main {
  color: var(--text-main);
}
.text-sub {
  color: var(--text-sub);
}
.text-assist {
  color: var(--text-assist);
}
.text-primary {
  color: var(--color-primary);
}

/* 覆盖默认 button 样式 */
button {
  background: initial;
  padding: 0;
  line-height: inherit;
}
button:focus {
  outline: 0;
}
button::after {
  border: none;
}
