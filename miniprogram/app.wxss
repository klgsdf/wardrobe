/**app.wxss - Ins 极简风电子衣柜（白·粉·蓝配色）**/

page {
  /* ===== Ins 极简风 · 白/粉/蓝配色 ===== */
  /* 主色：清新功能蓝 */
  --color-primary: #4A90E2;
  --color-primary-light: #6BA5E7;
  --color-primary-deep: #3A7BD5;
  --color-primary-gradient: linear-gradient(135deg, #5CA0E6, #4A90E2);

  /* 辅助色：柔和莫兰迪粉 */
  --color-pink: #F8BBD9;
  --color-pink-light: #FCE4EC;
  --color-pink-deep: #F48FB1;

  /* 背景：纯净白色 */
  --bg-start: #FFFFFF;
  --bg-end: #FFFFFF;
  --bg-page: #FFFFFF;

  /* 卡片：纯白 + 极淡灰边框，无阴影 */
  --card-bg: #FFFFFF;
  --card-border: rgba(0, 0, 0, 0.06);
  --card-bg-strong: #FFFFFF;
  --card-bg-solid: #FFFFFF;

  /* 表面层级：极简 */
  --surface-elevated: #FFFFFF;
  --surface-inner: #F8F9FA;
  --stats-bg: #FFFFFF;
  --ai-card-bg: #FFF5FA;
  --ai-card-border: rgba(0, 0, 0, 0.06);
  --ai-halo: transparent;

  /* 图标：蓝灰线条 */
  --icon-stroke: #8FA8C8;
  --icon-stroke-soft: rgba(143, 168, 200, 0.50);
  --icon-fill: transparent;

  /* 阴影：极简，几乎无阴影 */
  --shadow-soft: none;
  --shadow-card: none;
  --shadow-hover: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  --shadow-ios: none;

  /* 文字：深灰/浅灰 */
  --text-main: #333333;
  --text-sub: #999999;
  --text-assist: #BBBBBB;

  --nav-bg: rgba(255, 255, 255, 0.95);
  --line-soft: rgba(0, 0, 0, 0.06);
  --line-grid: #F0F2F5;

  /* ===== 极简场景 Token（白/粉/蓝） ===== */
  --scene-wall-top: #EDF2FA;
  --scene-wall-bottom: #E3EBF7;
  --scene-floor-top: #F5F0F7;
  --scene-floor-bottom: #EDE8F0;
  --scene-skirting: rgba(143, 168, 200, 0.20);
  --glass-panel: #F8FAFC;
  --glass-edge: rgba(0, 0, 0, 0.06);
  --glass-outline: rgba(143, 168, 200, 0.30);
  --led-glow: transparent;
  --led-line: transparent;
  --bridge-top: #EDF2FA;

  /* 圆角：极简小圆角 */
  --radius-xs: 8rpx;
  --radius-sm: 12rpx;
  --radius-tag: 12rpx;
  --radius-card: 16rpx;
  --radius-card-lg: 20rpx;
  --radius-btn: 9999rpx;

  background: var(--bg-page);
  min-height: 100vh;
  /* 极简无衬线细字体 */
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", "HarmonyOS Sans SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
  color: var(--text-main);
  font-size: 28rpx;
  line-height: 1.5;
  letter-spacing: 0.3rpx;
  -webkit-font-smoothing: antialiased;
}

/* 字体工具类（统一无衬线，保留 class 名向后兼容） */
.font-serif { font-family: inherit; font-weight: 600; letter-spacing: 1rpx; }
.font-sans  { font-family: inherit; }

/* ===== 深色主题（白/粉/蓝 暗色模式） ===== */
.theme-dark {
  /* 背景：深灰，非纯黑 */
  --bg-start: #1A1A1A;
  --bg-end:   #1A1A1A;
  --bg-page:  #1A1A1A;

  /* 主色：暗色下 muted 蓝 */
  --color-primary:       #5A9FE8;
  --color-primary-light: #7AB8FF;
  --color-primary-deep:  #4A8BD6;
  --color-primary-gradient: linear-gradient(135deg, #6BA5E7, #5A9FE8);

  /* 辅助色：暗色下 muted 粉 */
  --color-pink: #C48BA8;
  --color-pink-light: #A87B94;
  --color-pink-deep: #D48AA8;

  /* 卡片：深灰 */
  --card-bg:          #242424;
  --card-bg-strong:   #2A2A2A;
  --card-bg-solid:    #1E1E1E;
  --card-border:      rgba(255, 255, 255, 0.06);

  --surface-elevated: #242424;
  --surface-inner:    #2A2A2A;
  --stats-bg:         #242424;
  --ai-card-bg:       #2A2028;
  --ai-card-border:   rgba(255, 255, 255, 0.06);
  --ai-halo:          transparent;

  /* 图标：浅灰 */
  --icon-stroke:      #888888;
  --icon-stroke-soft: rgba(136, 136, 136, 0.50);
  --icon-fill:        transparent;

  /* 阴影：极简 */
  --shadow-soft:  none;
  --shadow-card:  none;
  --shadow-hover: 0 8rpx 24rpx rgba(0, 0, 0, 0.20);
  --shadow-ios: none;

  /* 文字：浅灰 */
  --text-main:   #E8E8E8;
  --text-sub:    #888888;
  --text-assist: #666666;

  --nav-bg:   rgba(26, 26, 26, 0.95);
  --line-soft: rgba(255, 255, 255, 0.06);
  --line-grid: rgba(255, 255, 255, 0.04);

  /* 场景盒 - 深色极简（粉蓝暗调） */
  --scene-wall-top:    #20242E;
  --scene-wall-bottom: #1A1E28;
  --scene-floor-top:   #1E1A1E;
  --scene-floor-bottom:#1A161A;
  --scene-skirting:    rgba(100, 130, 180, 0.15);
  --glass-panel:       #262A34;
  --glass-edge:        rgba(255, 255, 255, 0.06);
  --glass-outline:     rgba(100, 130, 180, 0.20);
  --led-glow:          transparent;
  --led-line:          transparent;
  --bridge-top:        #20242E;

  background: var(--bg-page);
  color: var(--text-main);
}

/* 通用容器 */
.container {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  width: 100%;
}

/* 玻璃态卡片 - Virtual Wardrobe */
.glass-card {
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  box-shadow: var(--shadow-soft);
  border-radius: var(--radius-card);
  box-sizing: border-box;
}

/* 主按钮 - 蓝色实心 + 大圆角 + 柔和投影 */
.btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 48rpx;
  background: var(--color-primary);
  color: #FFFFFF;
  border-radius: var(--radius-btn);
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 16rpx -4rpx rgba(74, 144, 226, 0.35);
  transition: transform 0.15s ease;
}

/* 次级按钮 - 玻璃态 */
.btn-ghost {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 48rpx;
  background: var(--card-bg);
  color: var(--color-primary);
  border: 1rpx solid var(--card-border);
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: var(--shadow-soft);
}

/* 按压反馈 */
.tap-scale {
  transition: transform 0.15s ease;
}
.tap-scale:active {
  transform: scale(0.97);
}

/* 文字层级工具类 */
.text-main {
  color: var(--text-main);
}
.text-sub {
  color: var(--text-sub);
}
.text-assist {
  color: var(--text-assist);
}
.text-primary {
  color: var(--color-primary);
}

/* 覆盖默认 button 样式 */
button {
  background: initial;
  padding: 0;
  line-height: inherit;
}
button:focus {
  outline: 0;
}
button::after {
  border: none;
}
