/* pages/profile/profile.wxss */
.placeholder {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  gap: 16rpx;
}
.placeholder__emoji { font-size: 120rpx; line-height: 1; }
.placeholder__title { font-size: 40rpx; font-weight: 600; color: #2D3748; letter-spacing: 4rpx; }
.placeholder__desc { font-size: 26rpx; color: #A0AEC0; }
