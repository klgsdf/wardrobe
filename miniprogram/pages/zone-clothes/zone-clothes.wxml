<!--pages/zone-clothes/zone-clothes.wxml - 分区衣物瀑布流页面-->
<view class="page-root {{isDark ? 'theme-dark' : ''}}">

  <!-- 状态栏 + 自定义导航栏占位 -->
  <view class="nav-pad" style="height: {{navPadHeight}}px;"></view>
  <view class="nav-bar" style="height: {{navPadHeight}}px;">
    <view class="nav-bar__left tap-scale" bindtap="onBack">
      <view class="ic-back">
        <view class="ic-back__line"></view>
        <view class="ic-back__arrow"></view>
      </view>
      <text class="nav-bar__back-text">返回</text>
    </view>
    <view class="nav-bar__title">{{selectMode ? '选择衣物' : zoneName}}</view>
    <view class="nav-bar__right">
      <view wx:if="{{!selectMode}}" class="icon-btn tap-scale" bindtap="onToggleTheme">
        <view wx:if="{{isDark}}" class="ic ic-sun">
          <view class="ic-sun__core"></view>
        </view>
        <view wx:else class="ic ic-moon">
          <view class="ic-moon__shape"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 页面主体 -->
  <scroll-view class="page-body" scroll-y bindscrolltolower="onScrollToLower" style="--nav-pad-height: {{navPadHeight}}px;">

    <!-- 衣物数量提示 -->
    <view wx:if="{{!isEmpty}}" class="count-bar">
      <text class="count-bar__text">共 {{allItems.length}} 件衣物</text>
    </view>

    <!-- 双列瀑布流 -->
    <view wx:if="{{!isEmpty}}" class="waterfall">
      <!-- 左列 -->
      <view class="waterfall__col">
        <view wx:for="{{leftColumn}}" wx:key="id"
              class="cloth-card tap-scale {{selectMode && item.isSelected ? 'is-selected' : ''}}"
              data-id="{{item.id}}"
              bindtap="onItemTap">
          <view class="cloth-card__img-wrap">
            <image class="cloth-card__img" src="{{item.images[0]}}" mode="aspectFill" lazy-load />
            <view wx:if="{{selectMode && item.isSelected}}" class="cloth-card__check">
              <view class="ic-check">
                <view class="ic-check__line1"></view>
                <view class="ic-check__line2"></view>
              </view>
            </view>
          </view>
          <view class="cloth-card__info">
            <!-- 颜色标签 -->
            <view wx:if="{{item.colorHexes.length > 0}}" class="cloth-card__colors">
              <view wx:for="{{item.colorHexes}}" wx:for-item="hex" wx:key="*this"
                    class="cloth-card__color-dot"
                    style="background: {{hex}}; {{hex === '#FFFFFF' ? 'border: 1rpx solid rgba(0,0,0,0.15);' : ''}}"></view>
            </view>
            <!-- 类别 + 季节标签 -->
            <view wx:if="{{item.categoryLabel || item.seasonLabel}}" class="cloth-card__tags">
              <text wx:if="{{item.categoryLabel}}" class="cloth-card__tag cloth-card__tag--cat">{{item.categoryLabel}}</text>
              <text wx:if="{{item.seasonLabel}}" class="cloth-card__tag">{{item.seasonLabel}}</text>
            </view>
            <!-- 时间 -->
            <view wx:if="{{item.createdAtStr}}" class="cloth-card__date">{{item.createdAtStr}}</view>
          </view>
        </view>
      </view>

      <!-- 右列 -->
      <view class="waterfall__col">
        <view wx:for="{{rightColumn}}" wx:key="id"
              class="cloth-card tap-scale {{selectMode && item.isSelected ? 'is-selected' : ''}}"
              data-id="{{item.id}}"
              bindtap="onItemTap">
          <view class="cloth-card__img-wrap">
            <image class="cloth-card__img" src="{{item.images[0]}}" mode="aspectFill" lazy-load />
            <view wx:if="{{selectMode && item.isSelected}}" class="cloth-card__check">
              <view class="ic-check">
                <view class="ic-check__line1"></view>
                <view class="ic-check__line2"></view>
              </view>
            </view>
          </view>
          <view class="cloth-card__info">
            <!-- 颜色标签 -->
            <view wx:if="{{item.colorHexes.length > 0}}" class="cloth-card__colors">
              <view wx:for="{{item.colorHexes}}" wx:for-item="hex" wx:key="*this"
                    class="cloth-card__color-dot"
                    style="background: {{hex}}; {{hex === '#FFFFFF' ? 'border: 1rpx solid rgba(0,0,0,0.15);' : ''}}"></view>
            </view>
            <!-- 类别 + 季节标签 -->
            <view wx:if="{{item.categoryLabel || item.seasonLabel}}" class="cloth-card__tags">
              <text wx:if="{{item.categoryLabel}}" class="cloth-card__tag cloth-card__tag--cat">{{item.categoryLabel}}</text>
              <text wx:if="{{item.seasonLabel}}" class="cloth-card__tag">{{item.seasonLabel}}</text>
            </view>
            <!-- 时间 -->
            <view wx:if="{{item.createdAtStr}}" class="cloth-card__date">{{item.createdAtStr}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{!isEmpty && hasMore}}" class="load-more">
      <view class="load-more__spinner"></view>
      <text class="load-more__text">加载中...</text>
    </view>
    <view wx:if="{{!isEmpty && !hasMore && allItems.length > 0}}" class="load-more load-more--end">
      <text>没有更多了</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{isEmpty}}" class="empty-state">
      <view class="empty-state__icon">
        <view class="ic-hanger-empty">
          <view class="ic-hanger-empty__rod"></view>
          <view class="ic-hanger-empty__hook"></view>
        </view>
      </view>
      <view class="empty-state__title">{{selectMode ? '该分区暂无衣物' : '该分区暂无衣物'}}</view>
      <view class="empty-state__desc">{{selectMode ? '请选择其他分区' : '去「添加衣物」页面添加并存放至此'}}</view>
    </view>

    <view class="safe-bottom"></view>
  </scroll-view>

  <!-- 选择模式底部操作栏 -->
  <view wx:if="{{selectMode}}" class="bottom-action-bar">
    <view class="bottom-action-bar__inner">
      <text class="bottom-action-bar__count">已选 {{selectedIds.length}} 件</text>
      <view class="bottom-action-bar__btn tap-scale {{selectedIds.length === 0 ? 'is-disabled' : ''}}" bindtap="onConfirmSelect">
        <text>完成</text>
      </view>
    </view>
    <view class="safe-bottom"></view>
  </view>
</view>
