<!--pages/wardrobe/wardrobe.wxml - 衣柜管理列表页-->
<view class="page-root {{isDark ? 'theme-dark' : ''}}">

  <!-- 自定义顶栏占位 -->
  <view class="nav-pad" style="height: {{navPadHeight}}px;"></view>
  <view class="nav-bar"
        style="top: {{menuBtnTop}}px; height: {{menuBtnHeight}}px;">
    <view class="nav-bar__title">{{selectMode ? '选择衣柜' : '我的衣柜'}}</view>
    <view class="nav-bar__spacer"></view>
    <view class="icon-btn tap-scale" bindtap="onToggleTheme"
          style="width: {{menuBtnHeight}}px; height: {{menuBtnHeight}}px;">
      <view wx:if="{{isDark}}" class="ic ic-sun">
        <view class="ic-sun__core"></view>
      </view>
      <view wx:else class="ic ic-moon">
        <view class="ic-moon__shape"></view>
      </view>
    </view>
  </view>

  <!-- 统计概览条 -->
  <view class="summary-bar">
    <view class="summary-bar__item">
      <text class="summary-bar__num">{{wardrobes.length}}</text>
      <text class="summary-bar__label">衣柜</text>
    </view>
    <view class="summary-bar__divider"></view>
    <view class="summary-bar__item">
      <text class="summary-bar__num">{{totalItems}}</text>
      <text class="summary-bar__label">衣物</text>
    </view>
    <view class="summary-bar__divider"></view>
    <view class="summary-bar__item">
      <text class="summary-bar__num">{{totalZones}}</text>
      <text class="summary-bar__label">分区</text>
    </view>
  </view>

  <!-- 添加按钮（条状设计） -->
  <view wx:if="{{!selectMode}}" class="add-bar tap-scale" bindtap="onShowAddSheet">
    <view class="add-bar__icon">
      <view class="add-bar__plus-h"></view>
      <view class="add-bar__plus-v"></view>
    </view>
    <text class="add-bar__text">添加衣柜</text>
  </view>

  <!-- 衣柜列表（垂直条状布局） -->
  <view class="wardrobe-list">
    <view wx:for="{{wardrobes}}" wx:key="id"
          class="wardrobe-item tap-scale"
          data-id="{{item.id}}"
          bindtap="onWardrobeTap"
          bindlongpress="onWardrobeLongPress">
      <!-- 左侧类型图标 -->
      <view class="wardrobe-item__icon wardrobe-item__icon--{{item.type}}">
        <view wx:if="{{item.type === 'closet'}}" class="ic-wardrobe">
          <view class="ic-wardrobe__box"></view>
          <view class="ic-wardrobe__split"></view>
          <view class="ic-wardrobe__handle ic-wardrobe__handle--l"></view>
          <view class="ic-wardrobe__handle ic-wardrobe__handle--r"></view>
        </view>
        <view wx:elif="{{item.type === 'drawer'}}" class="ic-drawer-type">
          <view class="ic-drawer-type__box"></view>
          <view class="ic-drawer-type__line ic-drawer-type__line--1"></view>
          <view class="ic-drawer-type__line ic-drawer-type__line--2"></view>
          <view class="ic-drawer-type__knob"></view>
        </view>
        <view wx:elif="{{item.type === 'shoe-rack'}}" class="ic-shoe-type">
          <view class="ic-shoe-type__frame"></view>
          <view class="ic-shoe-type__shelf ic-shoe-type__shelf--1"></view>
          <view class="ic-shoe-type__shelf ic-shoe-type__shelf--2"></view>
        </view>
        <view wx:elif="{{item.type === 'shelf'}}" class="ic-shelf-type">
          <view class="ic-shelf-type__frame"></view>
          <view class="ic-shelf-type__line ic-shelf-type__line--1"></view>
          <view class="ic-shelf-type__line ic-shelf-type__line--2"></view>
          <view class="ic-shelf-type__line ic-shelf-type__line--3"></view>
        </view>
        <view wx:elif="{{item.type === 'seasonal'}}" class="ic-box-type">
          <view class="ic-box-type__box"></view>
          <view class="ic-box-type__lid"></view>
        </view>
      </view>

      <!-- 中间信息 -->
      <view class="wardrobe-item__info">
        <view class="wardrobe-item__name">{{item.name}}</view>
        <view class="wardrobe-item__desc">{{item.desc}}</view>
        <view class="wardrobe-item__meta">
          <text class="wardrobe-item__zones">{{item.zones.length}} 个分区</text>
          <text class="wardrobe-item__dot">·</text>
          <text class="wardrobe-item__count">{{item.itemCount}} 件衣物</text>
        </view>
      </view>

      <!-- 右侧箭头 / 选择指示 -->
      <view class="wardrobe-item__arrow" wx:if="{{!selectMode}}">
        <view class="ic-arrow">
          <view class="ic-arrow__line"></view>
          <view class="ic-arrow__head"></view>
        </view>
      </view>
      <view class="wardrobe-item__select-indicator" wx:if="{{selectMode}}">
        <view class="ic-chevron-right">
          <view class="ic-chevron__line"></view>
          <view class="ic-chevron__head"></view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{wardrobes.length === 0}}" class="empty-state">
      <view class="empty-state__icon">
        <view class="ic-wardrobe-empty">
          <view class="ic-wardrobe-empty__box"></view>
          <view class="ic-wardrobe-empty__split"></view>
        </view>
      </view>
      <view class="empty-state__title">还没有衣柜</view>
      <view class="empty-state__desc">点击上方「添加衣柜」开始管理</view>
    </view>
  </view>

  <!-- ===== 添加衣柜弹窗 ===== -->
  <view wx:if="{{showAddSheet}}" class="overlay" bindtap="onHideAddSheet">
    <view class="add-sheet" catchtap="">
      <view class="add-sheet__header">
        <text class="add-sheet__title">添加新衣柜</text>
        <view class="add-sheet__close tap-scale" bindtap="onHideAddSheet">
          <view class="ic-close">
            <view class="ic-close__line ic-close__line--1"></view>
            <view class="ic-close__line ic-close__line--2"></view>
          </view>
        </view>
      </view>

      <!-- 类型选择 -->
      <view class="add-sheet__section">
        <view class="add-sheet__label">类型</view>
        <view class="type-grid">
          <view wx:for="{{typeOptions}}" wx:key="type"
                class="type-chip tap-scale {{addForm.type === item.type ? 'is-active' : ''}}"
                data-type="{{item.type}}" bindtap="onTypeSelect">
            <view class="type-chip__dot"></view>
            <text class="type-chip__text">{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- 名称输入 -->
      <view class="add-sheet__section">
        <view class="add-sheet__label">名称</view>
        <input class="add-sheet__input"
               placeholder="例如：主柜、抽屉、鞋柜"
               placeholder-class="add-sheet__placeholder"
               value="{{addForm.name}}"
               bindinput="onAddFormNameInput"
               maxlength="20" />
      </view>

      <!-- 描述输入 -->
      <view class="add-sheet__section">
        <view class="add-sheet__label">描述（选填）</view>
        <input class="add-sheet__input"
               placeholder="简短描述用途"
               placeholder-class="add-sheet__placeholder"
               value="{{addForm.desc}}"
               bindinput="onAddFormDescInput"
               maxlength="30" />
      </view>

      <!-- 确认按钮 -->
      <view class="add-sheet__btn tap-scale" bindtap="onConfirmAdd">
        <text>确认添加</text>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
