/* pages/wardrobe/wardrobe.wxss - 衣柜管理列表页 */

.page-root {
  width: 100%;
  min-height: 100vh;
  background: var(--bg-page);
  box-sizing: border-box;
}

.nav-pad { width: 100%; }

/* ============ 自定义顶栏 ============ */
.nav-bar {
  position: fixed;
  left: 32rpx;
  display: flex;
  align-items: center;
  z-index: 100;
  pointer-events: none;
}
.nav-bar > .nav-bar__title,
.nav-bar > .icon-btn { pointer-events: auto; }

.nav-bar__title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 1rpx;
  line-height: 1;
}

.nav-bar__spacer { flex: 1; }

.icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  box-shadow: none;
  box-sizing: border-box;
}

/* ============ 统计概览条 ============ */
.summary-bar {
  display: flex;
  align-items: center;
  margin: 16rpx 32rpx 0;
  padding: 28rpx 24rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: var(--radius-card);
}
.summary-bar__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.summary-bar__num {
  font-size: 44rpx;
  font-weight: 300;
  color: var(--text-main);
  letter-spacing: 0;
  line-height: 1;
  font-feature-settings: "tnum";
}
.summary-bar__label {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.5rpx;
  font-weight: 400;
}
.summary-bar__divider {
  width: 1rpx;
  height: 40rpx;
  background: var(--line-soft);
}

/* ============ 添加按钮（条状设计） ============ */
.add-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 24rpx 32rpx 0;
  padding: 24rpx 28rpx;
  background: transparent;
  border: 2rpx dashed var(--color-primary);
  border-radius: var(--radius-card);
  transition: all 0.2s ease;
}
.add-bar__icon {
  position: relative;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.add-bar__plus-h,
.add-bar__plus-v {
  position: absolute;
  top: 50%; left: 50%;
  background: var(--color-primary);
  border-radius: 2rpx;
  transform: translate(-50%, -50%);
}
.add-bar__plus-h { width: 24rpx; height: 2rpx; }
.add-bar__plus-v { width: 2rpx; height: 24rpx; }
.add-bar__text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-primary);
  letter-spacing: 1rpx;
}

/* ============ 衣柜列表（垂直条状） ============ */
.wardrobe-list {
  padding: 0 32rpx;
  margin-top: 20rpx;
}

.wardrobe-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: var(--radius-card);
  transition: all 0.2s ease;
  position: relative;
}

.wardrobe-item:active {
  border-color: var(--color-primary);
}

/* ---- 左侧类型图标 ---- */
.wardrobe-item__icon {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-inner);
  border: 1rpx solid var(--card-border);
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}

/* 衣柜图标 */
.ic-wardrobe { position: relative; width: 40rpx; height: 48rpx; }
.ic-wardrobe__box {
  position: absolute; inset: 0;
  border: 2rpx solid var(--icon-stroke);
  border-radius: 4rpx; box-sizing: border-box;
}
.ic-wardrobe__split {
  position: absolute; top: 0; bottom: 0; left: 50%;
  width: 2rpx; background: var(--icon-stroke);
  transform: translateX(-50%);
}
.ic-wardrobe__handle {
  position: absolute; top: 40%;
  width: 3rpx; height: 10rpx;
  background: var(--icon-stroke);
  border-radius: 2rpx;
}
.ic-wardrobe__handle--l { right: 52%; }
.ic-wardrobe__handle--r { left: 52%; }

/* 抽屉图标 */
.ic-drawer-type { position: relative; width: 44rpx; height: 40rpx; }
.ic-drawer-type__box {
  position: absolute; inset: 0;
  border: 2rpx solid var(--icon-stroke);
  border-radius: 4rpx; box-sizing: border-box;
}
.ic-drawer-type__line {
  position: absolute; left: 6rpx; right: 6rpx;
  height: 2rpx; background: var(--icon-stroke);
}
.ic-drawer-type__line--1 { top: 40%; }
.ic-drawer-type__line--2 { top: 70%; }
.ic-drawer-type__knob {
  position: absolute; bottom: 16%;
  left: 50%; width: 10rpx; height: 3rpx;
  margin-left: -5rpx; background: var(--icon-stroke);
  border-radius: 2rpx;
}

/* 鞋架图标 */
.ic-shoe-type { position: relative; width: 44rpx; height: 48rpx; }
.ic-shoe-type__frame {
  position: absolute; inset: 0;
  border: 2rpx solid var(--icon-stroke);
  border-radius: 4rpx; box-sizing: border-box;
}
.ic-shoe-type__shelf {
  position: absolute; left: 6rpx; right: 6rpx;
  height: 2rpx; background: var(--icon-stroke);
}
.ic-shoe-type__shelf--1 { top: 35%; }
.ic-shoe-type__shelf--2 { top: 65%; }

/* 置物架图标 */
.ic-shelf-type { position: relative; width: 44rpx; height: 48rpx; }
.ic-shelf-type__frame {
  position: absolute; inset: 0;
  border: 2rpx solid var(--icon-stroke);
  border-radius: 4rpx; box-sizing: border-box;
}
.ic-shelf-type__line {
  position: absolute; left: 4rpx; right: 4rpx;
  height: 2rpx; background: var(--icon-stroke);
}
.ic-shelf-type__line--1 { top: 25%; }
.ic-shelf-type__line--2 { top: 50%; }
.ic-shelf-type__line--3 { top: 75%; }

/* 收纳箱图标 */
.ic-box-type { position: relative; width: 44rpx; height: 40rpx; }
.ic-box-type__box {
  position: absolute; bottom: 0; left: 0; right: 0;
  height: 30rpx;
  border: 2rpx solid var(--icon-stroke);
  border-radius: 0 0 4rpx 4rpx; box-sizing: border-box;
}
.ic-box-type__lid {
  position: absolute; top: 0; left: -2rpx; right: -2rpx;
  height: 12rpx;
  border: 2rpx solid var(--icon-stroke);
  border-radius: 4rpx 4rpx 0 0; box-sizing: border-box;
}

/* ---- 中间信息 ---- */
.wardrobe-item__info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.wardrobe-item__name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
  letter-spacing: 0.5rpx;
  line-height: 1.3;
}
.wardrobe-item__desc {
  font-size: 24rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.wardrobe-item__meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 4rpx;
}
.wardrobe-item__zones,
.wardrobe-item__count {
  font-size: 22rpx;
  color: var(--text-assist);
  letter-spacing: 0.3rpx;
}
.wardrobe-item__dot {
  font-size: 22rpx;
  color: var(--text-assist);
}

/* ---- 右侧箭头 ---- */
.wardrobe-item__arrow {
  flex-shrink: 0;
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ic-arrow {
  position: relative;
  width: 16rpx;
  height: 16rpx;
}
.ic-arrow__line {
  position: absolute;
  top: 50%; left: 0;
  width: 12rpx; height: 2rpx;
  background: var(--text-assist);
  margin-top: -1rpx;
  border-radius: 1rpx;
}
.ic-arrow__head {
  position: absolute;
  top: 50%; right: 0;
  width: 8rpx; height: 8rpx;
  border-top: 2rpx solid var(--text-assist);
  border-right: 2rpx solid var(--text-assist);
  transform: rotate(45deg);
  margin-top: -4rpx;
}

/* ============ 空状态 ============ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}
.empty-state__icon {
  width: 120rpx; height: 120rpx;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 24rpx;
  opacity: 0.4;
}
.ic-wardrobe-empty { position: relative; width: 64rpx; height: 72rpx; }
.ic-wardrobe-empty__box {
  position: absolute; inset: 0;
  border: 3rpx solid var(--icon-stroke);
  border-radius: 8rpx; box-sizing: border-box;
}
.ic-wardrobe-empty__split {
  position: absolute; top: 0; bottom: 0; left: 50%;
  width: 3rpx; background: var(--icon-stroke);
  transform: translateX(-50%);
}
.empty-state__title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-sub);
  letter-spacing: 1rpx;
}
.empty-state__desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-assist);
}

/* ============ 添加弹窗（底部抽屉） ============ */
.overlay {
  position: fixed;
  inset: 0;
  z-index: 500;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  animation: fadeIn 0.2s ease;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.add-sheet {
  width: 100%;
  max-height: 85vh;
  padding: 32rpx 32rpx calc(env(safe-area-inset-bottom) + 32rpx);
  background: var(--surface-elevated);
  border-top-left-radius: var(--radius-card-lg);
  border-top-right-radius: var(--radius-card-lg);
  box-sizing: border-box;
  animation: slideUp 0.28s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.add-sheet__header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}
.add-sheet__title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 1rpx;
}
.add-sheet__spacer { flex: 1; }
.add-sheet__close {
  width: 48rpx; height: 48rpx;
  display: flex; align-items: center; justify-content: center;
}
.ic-close { position: relative; width: 24rpx; height: 24rpx; }
.ic-close__line {
  position: absolute; top: 50%; left: 50%;
  width: 24rpx; height: 2rpx;
  background: var(--text-sub);
  border-radius: 1rpx;
}
.ic-close__line--1 { transform: translate(-50%, -50%) rotate(45deg); }
.ic-close__line--2 { transform: translate(-50%, -50%) rotate(-45deg); }

.add-sheet__section {
  margin-bottom: 28rpx;
}
.add-sheet__label {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-sub);
  letter-spacing: 0.5rpx;
  margin-bottom: 16rpx;
}

/* 类型选择网格 */
.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.type-chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 24rpx;
  background: var(--surface-inner);
  border: 2rpx solid var(--card-border);
  border-radius: var(--radius-btn);
  transition: all 0.2s ease;
}
.type-chip.is-active {
  border-color: var(--color-primary);
  background: rgba(74, 144, 226, 0.08);
}
.type-chip__dot {
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  background: var(--text-assist);
  transition: background 0.2s ease;
}
.type-chip.is-active .type-chip__dot {
  background: var(--color-primary);
}
.type-chip__text {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-main);
  letter-spacing: 0.5rpx;
}

/* 输入框 */
.add-sheet__input {
  width: 100%;
  padding: 20rpx 24rpx;
  background: var(--surface-inner);
  border: 2rpx solid var(--card-border);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--text-main);
  letter-spacing: 0.5rpx;
  box-sizing: border-box;
}
.add-sheet__placeholder {
  color: var(--text-assist);
  font-size: 28rpx;
}

/* 确认按钮 */
.add-sheet__btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  margin-top: 12rpx;
  background: var(--color-primary);
  border-radius: var(--radius-btn);
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 1rpx;
  box-shadow: 0 8rpx 16rpx -4rpx rgba(74, 144, 226, 0.35);
}

/* ============ 太阳/月亮图标（复用首页样式） ============ */
.ic { position: relative; display: inline-block; vertical-align: middle; }

.ic-sun { width: 32rpx; height: 32rpx; display: inline-flex; align-items: center; justify-content: center; }
.ic-sun__core {
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  border: 2rpx solid var(--icon-stroke);
  background: transparent;
  box-sizing: border-box;
  box-shadow:
     0      -12rpx 0 -5rpx var(--icon-stroke),
     0       12rpx 0 -5rpx var(--icon-stroke),
    -12rpx   0     0 -5rpx var(--icon-stroke),
     12rpx   0     0 -5rpx var(--icon-stroke),
    -8rpx -8rpx  0 -6rpx var(--icon-stroke),
     8rpx -8rpx  0 -6rpx var(--icon-stroke),
    -8rpx  8rpx  0 -6rpx var(--icon-stroke),
     8rpx  8rpx  0 -6rpx var(--icon-stroke);
}

.ic-moon { width: 32rpx; height: 32rpx; position: relative; display: inline-block; }
.ic-moon__shape {
  position: absolute; inset: 0;
  border-radius: 50%;
  background: var(--icon-stroke);
  overflow: hidden;
}
.ic-moon__shape::after {
  content: ''; position: absolute;
  top: -4rpx; right: -10rpx;
  width: 26rpx; height: 26rpx;
  border-radius: 50%;
  background: var(--surface-elevated);
}
.page-root.theme-dark .ic-moon__shape::after { background: var(--bg-start); }

.safe-bottom { height: calc(env(safe-area-inset-bottom) + 120rpx); }

.tap-scale { transition: transform 0.15s ease; }
.tap-scale:active { transform: scale(0.97); }
