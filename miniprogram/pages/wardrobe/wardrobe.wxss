/* pages/wardrobe/wardrobe.wxss - 衣柜 DIY 页 */

.page-root {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, var(--bg-start) 0%, var(--bridge-top) 55%, var(--bg-end) 100%);
  transition: background 0.4s ease;
  box-sizing: border-box;
  padding-bottom: 16rpx;
}

.nav-pad { width: 100%; }

/* ============ 顶栏：重置 / 完成 ============ */
.diy-header {
  position: fixed;
  left: 24rpx; right: 24rpx;
  z-index: 50;
  display: flex;
  align-items: center;
}
.diy-header__spacer { flex: 1; }
.diy-header__btn {
  display: inline-flex;
  align-items: center;
  padding: 0 28rpx;
  background: var(--surface-elevated);
  border: 1rpx solid var(--card-border);
  border-radius: 9999rpx;
  box-shadow: var(--shadow-soft);
  box-sizing: border-box;
}
.diy-header__btn--primary {
  background: var(--color-primary);
  border-color: var(--color-primary);
  box-shadow: 0 6rpx 14rpx -4rpx rgba(212, 163, 115, 0.5);
}
.diy-header__btn-text {
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  color: var(--text-main);
  line-height: 1;
}
.diy-header__btn--primary .diy-header__btn-text { color: #FFFFFF; }

/* ============ 标题 ============ */
.diy-title {
  padding: 20rpx 40rpx 16rpx;
}
.diy-title__main {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 2rpx;
  line-height: 1.1;
}
.diy-title__sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-sub);
  letter-spacing: 1rpx;
}

/* ============ 画布区：场景盒 + 悬浮衣柜 ============ */
.canvas-area {
  position: relative;
  margin: 0 28rpx;
  height: 52vh;
  min-height: 580rpx;
  border-radius: var(--radius-card-lg);
  overflow: hidden;
  box-shadow:
    0 24rpx 60rpx -20rpx rgba(184, 136, 85, 0.3),
    0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.scene { position: absolute; inset: 0; }
.scene__wall {
  position: absolute; top: 0; left: 0; right: 0; height: 75%;
  background: linear-gradient(180deg, var(--scene-wall-top) 0%, var(--scene-wall-bottom) 100%);
}
.scene__floor {
  position: absolute; bottom: 0; left: 0; right: 0; height: 25%;
  background: linear-gradient(180deg, var(--scene-floor-top) 0%, var(--scene-floor-bottom) 100%);
}
.scene__skirting {
  position: absolute; left: 0; right: 0; top: 75%;
  height: 2rpx; background: var(--scene-skirting);
}
.scene__light-halo {
  position: absolute; top: -10%; left: 50%;
  width: 140%; height: 70%;
  margin-left: -70%;
  background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.55) 0%, rgba(255, 255, 255, 0) 60%);
  pointer-events: none;
}
.page-root.theme-dark .scene__light-halo {
  background: radial-gradient(ellipse at center, rgba(230, 184, 136, 0.18) 0%, rgba(230, 184, 136, 0) 60%);
}

/* ============ 画布内玻璃衣柜 ============ */
.canvas-closet {
  position: absolute;
  top: 6%; bottom: 8%;
  left: 14%; right: 14%;
  z-index: 4;
}

.canvas-closet__shadow {
  position: absolute;
  left: 8%; right: 8%;
  bottom: -16rpx;
  height: 40rpx;
  background: radial-gradient(ellipse at center, rgba(58, 40, 24, 0.35) 0%, rgba(58, 40, 24, 0) 70%);
  filter: blur(6rpx);
}

.canvas-closet__frame {
  position: relative;
  width: 100%; height: 100%;
  background: var(--glass-panel);
  border: 2rpx solid var(--glass-edge);
  border-radius: 20rpx;
  box-shadow:
    0 20rpx 50rpx -10rpx rgba(184, 136, 85, 0.32),
    0 0 0 1rpx rgba(255, 255, 255, 0.6) inset;
  box-sizing: border-box;
  transform: translateY(-6rpx);
  backdrop-filter: blur(6rpx);
  -webkit-backdrop-filter: blur(6rpx);
  overflow: visible;
}
.page-root.theme-dark .canvas-closet__frame {
  box-shadow:
    0 20rpx 50rpx -10rpx rgba(230, 184, 136, 0.35),
    0 0 0 1rpx rgba(230, 184, 136, 0.25) inset;
}

.canvas-closet__gloss {
  position: absolute;
  top: 0; left: 0; right: 40%;
  height: 40%;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.35) 0%, rgba(255, 255, 255, 0) 55%);
  pointer-events: none;
  border-top-left-radius: 20rpx;
}

/* ---- 热区基础 ---- */
.zone {
  position: absolute;
  box-sizing: border-box;
  transition: all 0.25s ease;
  border-radius: 6rpx;
  z-index: 1;
}
.zone.is-active {
  box-shadow:
    0 0 0 2rpx var(--color-primary),
    0 0 20rpx rgba(212, 163, 115, 0.4);
  z-index: 5;
}
.zone.is-active::after {
  content: ''; position: absolute;
  top: -10rpx; right: -10rpx;
  width: 16rpx; height: 16rpx;
  background: var(--color-primary);
  border-radius: 50%;
  box-shadow: 0 0 0 4rpx rgba(212, 163, 115, 0.3);
}

.zone--lighting { top: 0; left: 8rpx; right: 8rpx; height: 10%; }
.zone--topshelf { top: 10%; left: 8rpx; right: 8rpx; height: 18%; }
.zone--hanger   { top: 28%; left: 0;   width: 52%;  bottom: 28%; padding: 0 12rpx; }
.zone--doors    { top: 28%; right: 0;  width: 48%;  bottom: 28%; padding: 0 10rpx; }
.zone--drawers  { bottom: 0; left: 0; right: 0; height: 26%; display: flex; flex-direction: column; padding: 0 8rpx 8rpx; gap: 4rpx; }
.zone--accessories {
  bottom: 10rpx; left: -70rpx;
  width: 72rpx; height: 120rpx;
  z-index: 6;
}

/* ---- LED 灯带 ---- */
.c-led {
  position: absolute;
  top: 16rpx; left: 10rpx; right: 10rpx;
  height: 4rpx;
  background: var(--led-line);
  border-radius: 4rpx;
  box-shadow:
    0 6rpx 22rpx 2rpx var(--led-glow),
    0 0 10rpx 0 var(--led-glow);
}
.c-led.led--sensor { opacity: 0.65; animation: led-breath 2.4s ease-in-out infinite; }
.c-led.led--strip { height: 7rpx; top: 14rpx; }
@keyframes led-breath {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 0.85; }
}

/* ---- 隔板 / 折叠物 ---- */
.c-shelf {
  position: absolute;
  left: 8rpx; right: 8rpx;
  bottom: 0;
  height: 2rpx;
  background: var(--glass-outline);
  box-shadow: 0 1rpx 0 rgba(255, 255, 255, 0.5);
}
.c-shelf__divider {
  position: absolute;
  top: 20%; bottom: 6rpx;
  width: 2rpx;
  background: var(--glass-outline);
  opacity: 0.6;
}
.c-shelf__divider--a { left: 33%; }
.c-shelf__divider--b { left: 67%; }
.c-folds {
  position: absolute;
  top: 35%; left: 12%; right: 12%; bottom: 10rpx;
  display: flex; align-items: flex-end; justify-content: space-around;
  gap: 8rpx;
}
.c-fold {
  flex: 1;
  background: #FFFDF5;
  border: 1rpx solid var(--glass-outline);
  border-radius: 3rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.06);
}
.c-fold--a { height: 70%; }
.c-fold--b { height: 90%; }
.c-fold--c { height: 60%; }
.page-root.theme-dark .c-fold { background: #3A2B20; border-color: rgba(230, 184, 136, 0.4); }

/* ---- 挂衣杆 + 挂衣区 ---- */
.c-rod {
  position: absolute;
  left: 12rpx; right: 12rpx;
  top: 14rpx;
  height: 3rpx;
  background: var(--glass-outline);
  border-radius: 2rpx;
}
.c-rod--double,
.c-rod--extendable { top: 10rpx; }
.c-rod--lower { top: 55%; }
.c-rod--extendable::after {
  content: ''; position: absolute; right: -4rpx; top: -3rpx;
  width: 8rpx; height: 9rpx;
  border-radius: 50%;
  background: var(--color-primary);
}
.c-hang {
  position: absolute;
  top: 26rpx; left: 0; right: 0; bottom: 8rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-around;
  padding: 0 6rpx;
}
.c-hang .ic-shirt,
.c-hang .ic-dress,
.c-hang .ic-coat {
  transform: scale(0.7);
  transform-origin: top center;
}

/* ---- 门 ---- */
.c-door-panel {
  position: relative;
  width: 100%; height: 100%;
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.88) 0%, rgba(255, 253, 245, 0.78) 100%);
  border: 2rpx solid var(--glass-outline);
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05) inset;
}
.page-root.theme-dark .c-door-panel {
  background: linear-gradient(160deg, rgba(58, 43, 32, 0.9) 0%, rgba(46, 36, 29, 0.85) 100%);
}
.c-door-handle {
  position: absolute;
  top: 50%; left: 0;
  width: 7rpx; height: 48rpx;
  margin-top: -24rpx;
  background: var(--color-primary-deep);
  border-radius: 4rpx;
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
}
.c-door-dots {
  position: absolute;
  inset: 18rpx 14rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-auto-rows: 1fr;
  gap: 6rpx;
  place-items: center;
}
.c-door-dots__dot {
  width: 8rpx; height: 8rpx;
  border-radius: 50%;
  background: rgba(184, 136, 85, 0.45);
}
.page-root.theme-dark .c-door-dots__dot { background: rgba(230, 184, 136, 0.55); }
.c-door-louvers {
  position: absolute;
  inset: 18rpx 10rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
}
.c-door-louvers__bar {
  height: 3rpx;
  background: var(--glass-outline);
  border-radius: 2rpx;
  opacity: 0.6;
}
.c-door-swing {
  position: absolute;
  top: 10%; bottom: 10%; left: 50%;
  width: 1rpx;
  background: var(--glass-outline);
  opacity: 0.6;
}
.c-door-mirror {
  position: absolute;
  inset: 10rpx;
  background: linear-gradient(135deg, rgba(230, 220, 200, 0.9) 0%, rgba(255, 255, 255, 0.7) 35%, rgba(230, 220, 200, 0.9) 100%);
  border-radius: 4rpx;
}
.page-root.theme-dark .c-door-mirror {
  background: linear-gradient(135deg, rgba(74, 56, 40, 0.9) 0%, rgba(230, 184, 136, 0.3) 35%, rgba(74, 56, 40, 0.9) 100%);
}
.zone--doors.door--open .c-door-panel { background: transparent; border: none; }
.zone--doors.door--open .c-door-handle { display: none; }

/* ---- 抽屉 ---- */
.c-drawer {
  flex: 1;
  position: relative;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.6) 0%, rgba(255, 253, 245, 0.4) 100%);
  border: 1.5rpx solid var(--glass-outline);
  border-radius: 4rpx;
}
.page-root.theme-dark .c-drawer {
  background: linear-gradient(180deg, rgba(58, 43, 32, 0.6) 0%, rgba(46, 36, 29, 0.4) 100%);
}
.c-drawer__notch {
  position: absolute;
  top: 50%; left: 50%;
  width: 48rpx; height: 5rpx;
  margin-left: -24rpx;
  margin-top: -2.5rpx;
  background: var(--glass-outline);
  border-radius: 3rpx;
  opacity: 0.75;
}
.drawers--4 .c-drawer:first-child { flex: 0.6; }

/* ---- 鞋架（左侧悬浮） ---- */
.c-shoe {
  width: 100%; height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  padding: 6rpx 0;
  box-sizing: border-box;
  background: var(--glass-panel);
  border: 2rpx solid var(--glass-edge);
  border-radius: 8rpx;
  box-shadow: 0 8rpx 20rpx -6rpx rgba(184, 136, 85, 0.3);
}
.c-shoe__level {
  height: 3rpx;
  margin: 0 4rpx;
  background: var(--glass-outline);
  border-radius: 2rpx;
  position: relative;
}
.c-shoe__level::before,
.c-shoe__level::after {
  content: '';
  position: absolute;
  bottom: 0;
  width: 12rpx; height: 5rpx;
  background: var(--color-primary-light);
  border-radius: 6rpx 6rpx 0 0;
}
.c-shoe__level::before { left: 12rpx; }
.c-shoe__level::after  { right: 12rpx; }
.c-shoe--shoe-slant .c-shoe__level { transform: rotate(-8deg); }

/* ============ 工具抽屉（Tabs + 组件列表） ============ */
.tool-drawer {
  margin-top: 24rpx;
  padding: 20rpx 0 16rpx;
  background: var(--surface-elevated);
  border-top: 1rpx solid var(--card-border);
  border-top-left-radius: var(--radius-card-lg);
  border-top-right-radius: var(--radius-card-lg);
  box-shadow: 0 -8rpx 30rpx -10rpx rgba(0, 0, 0, 0.08);
}
.page-root.theme-dark .tool-drawer {
  background: var(--surface-elevated);
}

.tool-drawer__tabs {
  white-space: nowrap;
  padding: 0 28rpx;
}
.tool-tab {
  display: inline-flex;
  align-items: center;
  height: 60rpx;
  padding: 0 28rpx;
  margin-right: 12rpx;
  background: transparent;
  border: 1rpx solid var(--card-border);
  border-radius: 9999rpx;
  font-size: 26rpx;
  color: var(--text-sub);
  letter-spacing: 1rpx;
  transition: all 0.2s ease;
  box-sizing: border-box;
}
.tool-tab.is-active {
  background: var(--color-primary);
  border-color: var(--color-primary);
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx -2rpx rgba(212, 163, 115, 0.45);
}

.tool-drawer__list {
  white-space: nowrap;
  margin-top: 20rpx;
  padding: 8rpx 28rpx 16rpx;
}
.tool-card {
  position: relative;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 200rpx;
  padding: 20rpx 16rpx 18rpx;
  margin-right: 20rpx;
  background: var(--surface-inner);
  border: 2rpx solid var(--card-border);
  border-radius: 24rpx;
  box-sizing: border-box;
  vertical-align: top;
  transition: all 0.2s ease;
}
.tool-card.is-picked {
  border-color: var(--color-primary);
  box-shadow:
    0 0 0 2rpx rgba(212, 163, 115, 0.25),
    0 8rpx 20rpx -6rpx rgba(212, 163, 115, 0.3);
}
.tool-card__preview {
  position: relative;
  width: 100%;
  height: 110rpx;
  margin-bottom: 12rpx;
  background: var(--surface-elevated);
  border: 1rpx solid var(--card-border);
  border-radius: 12rpx;
  overflow: hidden;
}
.tool-card__label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-main);
  line-height: 1.2;
  letter-spacing: 0.5rpx;
}
.tool-card__desc {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: var(--text-sub);
  letter-spacing: 0.5rpx;
  line-height: 1.2;
}
.tool-card__check {
  position: absolute;
  top: 10rpx; right: 10rpx;
  width: 32rpx; height: 32rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 50%;
  box-shadow: 0 2rpx 6rpx rgba(212, 163, 115, 0.5);
}

/* ===== 预览微图标 ===== */
/* 推拉门 */
.pv-sliding {
  position: absolute;
  inset: 16rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  place-items: center;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 6rpx;
}
.page-root.theme-dark .pv-sliding { background: rgba(58, 43, 32, 0.6); }
.pv-sliding__dot { width: 8rpx; height: 8rpx; border-radius: 50%; background: rgba(184, 136, 85, 0.55); }

/* 平开门 */
.pv-swing {
  position: absolute;
  inset: 16rpx;
  border: 2rpx solid var(--glass-outline);
  border-radius: 4rpx;
  background: rgba(255, 255, 255, 0.55);
}
.pv-swing::after {
  content: ''; position: absolute;
  top: 10%; bottom: 10%; left: 50%;
  width: 1rpx; background: var(--glass-outline);
}
.page-root.theme-dark .pv-swing { background: rgba(58, 43, 32, 0.55); }

/* 百叶门 */
.pv-louver {
  position: absolute;
  inset: 16rpx;
  display: flex; flex-direction: column; justify-content: space-around;
  background: rgba(255, 255, 255, 0.55);
  border: 2rpx solid var(--glass-outline);
  border-radius: 4rpx;
}
.page-root.theme-dark .pv-louver { background: rgba(58, 43, 32, 0.55); }
.pv-louver__bar { height: 3rpx; margin: 0 8rpx; background: var(--glass-outline); border-radius: 2rpx; opacity: 0.7; }

/* 镜面门 */
.pv-mirror {
  position: absolute;
  inset: 16rpx;
  border-radius: 4rpx;
  background: linear-gradient(135deg, rgba(230, 220, 200, 0.9) 0%, rgba(255, 255, 255, 0.7) 35%, rgba(230, 220, 200, 0.9) 100%);
}
.page-root.theme-dark .pv-mirror {
  background: linear-gradient(135deg, rgba(74, 56, 40, 0.9) 0%, rgba(230, 184, 136, 0.3) 35%, rgba(74, 56, 40, 0.9) 100%);
}

/* 开放式 */
.pv-open {
  position: absolute;
  inset: 16rpx;
  border: 2rpx dashed var(--glass-outline);
  border-radius: 4rpx;
  opacity: 0.6;
}

/* 抽屉预览 */
.pv-drawers {
  position: absolute;
  inset: 12rpx 18rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.pv-drawer {
  flex: 1;
  border: 1.5rpx solid var(--glass-outline);
  border-radius: 3rpx;
  background: rgba(255, 255, 255, 0.55);
  position: relative;
}
.pv-drawer::after {
  content: ''; position: absolute;
  top: 50%; left: 50%;
  width: 24rpx; height: 3rpx;
  margin-left: -12rpx; margin-top: -1.5rpx;
  background: var(--glass-outline);
  border-radius: 2rpx;
}
.page-root.theme-dark .pv-drawer { background: rgba(58, 43, 32, 0.5); }
.pv-drawers--4 .pv-drawer:first-child { flex: 0.5; }

/* 挂衣杆预览 */
.pv-hanger {
  position: absolute;
  inset: 18rpx;
}
.pv-hanger__rod {
  position: absolute;
  top: 20%; left: 0; right: 0;
  height: 3rpx;
  background: var(--glass-outline);
  border-radius: 2rpx;
}
.pv-hanger__rod--low { top: 60%; }
.pv-hanger__knob {
  position: absolute;
  top: 18%; right: -4rpx;
  width: 8rpx; height: 9rpx;
  border-radius: 50%;
  background: var(--color-primary);
}
.pv-hanger::before {
  content: ''; position: absolute;
  top: 25%; left: 20%;
  width: 24rpx; height: 30rpx;
  border: 2rpx solid var(--icon-stroke);
  border-radius: 4rpx;
  background: var(--icon-fill);
}
.pv-hanger::after {
  content: ''; position: absolute;
  top: 25%; right: 20%;
  width: 24rpx; height: 30rpx;
  border: 2rpx solid var(--icon-stroke);
  border-radius: 4rpx;
  background: var(--icon-fill);
}

/* 置物架预览 */
.pv-shelf {
  position: absolute;
  inset: 18rpx;
}
.pv-shelf__line {
  position: absolute;
  top: 50%; left: 0; right: 0;
  height: 3rpx;
  background: var(--glass-outline);
  border-radius: 2rpx;
}
.pv-shelf__light {
  position: absolute;
  top: 45%; left: 5%; right: 5%;
  height: 4rpx;
  background: var(--led-line);
  border-radius: 4rpx;
  box-shadow: 0 0 12rpx 2rpx var(--led-glow);
}
.pv-shelf__grid {
  position: absolute;
  top: 55%; left: 0; right: 0; bottom: 10%;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4rpx;
}
.pv-shelf__grid > view {
  border: 1rpx solid var(--glass-outline);
  border-radius: 2rpx;
  opacity: 0.7;
}

/* 鞋架预览 */
.pv-shoe {
  position: absolute;
  inset: 16rpx 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  border: 1rpx solid var(--glass-outline);
  border-radius: 4rpx;
}
.pv-shoe__level {
  height: 2rpx;
  margin: 0 4rpx;
  background: var(--glass-outline);
  border-radius: 2rpx;
  position: relative;
}
.pv-shoe__level::before,
.pv-shoe__level::after {
  content: '';
  position: absolute;
  bottom: 0;
  width: 10rpx; height: 4rpx;
  background: var(--color-primary-light);
  border-radius: 4rpx 4rpx 0 0;
}
.pv-shoe__level::before { left: 8rpx; }
.pv-shoe__level::after  { right: 8rpx; }
.pv-shoe--shoe-slant .pv-shoe__level { transform: rotate(-8deg); }
.pv-shoe__x {
  position: absolute;
  top: 50%; left: 50%;
  width: 40rpx; height: 2rpx;
  margin-left: -20rpx; margin-top: -1rpx;
  background: var(--text-sub);
  opacity: 0.5;
}

/* 灯光预览 */
.pv-light {
  position: absolute;
  inset: 0;
}
.pv-light__strip {
  position: absolute;
  top: 30%; left: 15%; right: 15%;
  height: 4rpx;
  background: var(--led-line);
  border-radius: 4rpx;
}
.pv-light--strip .pv-light__strip { height: 7rpx; }
.pv-light__glow {
  position: absolute;
  top: 10%; left: 10%; right: 10%;
  height: 50%;
  background: radial-gradient(ellipse at top, var(--led-glow) 0%, transparent 70%);
  border-radius: 50%;
}
.pv-light--sensor .pv-light__strip { animation: led-breath 2s ease-in-out infinite; }
.pv-light__x {
  position: absolute;
  top: 50%; left: 50%;
  width: 44rpx; height: 2rpx;
  margin-left: -22rpx; margin-top: -1rpx;
  background: var(--text-sub);
  opacity: 0.5;
}

.safe-bottom { height: calc(env(safe-area-inset-bottom) + 120rpx); }

.tap-scale { transition: transform 0.15s ease; }
.tap-scale:active { transform: scale(0.97); }
