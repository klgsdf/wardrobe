/* pages/index/index.wxss - 焦糖米黄风首页 */

/* ============ 页面根 ============ */
.page-root {
  width: 100%;
  height: 100vh;
  background: var(--bg-page);
  display: flex;
  flex-direction: column;
}

/* ============ 顶部导航栏 ============ */
.nav-actions {
  position: fixed;
  left: 32rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 100;
  pointer-events: none;
}
.nav-actions > .wardrobe-name,
.nav-actions > .icon-btn { pointer-events: auto; }
.nav-actions__spacer { flex: 1; }

.page-body {
  flex: 1;
  box-sizing: border-box;
  padding: 0 32rpx 0;
  overflow-y: auto;
}

/* ============ 衣柜名字 ============ */
.wardrobe-name {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 0;
  background: transparent;
  border: none;
  box-shadow: none;
  box-sizing: border-box;
}
.wardrobe-name__text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
  line-height: 1;
}
.wardrobe-name__chev {
  width: 10rpx;
  height: 10rpx;
  border-right: 2rpx solid var(--text-sub);
  border-bottom: 2rpx solid var(--text-sub);
  transform: rotate(45deg);
  margin-top: -2rpx;
}

.icon-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  box-shadow: none;
  box-sizing: border-box;
}

/* 更多按钮 */
.icon-btn--more {
  margin-left: 4rpx;
}

/* ============ 收藏的搭配区域 ============ */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  margin-bottom: 20rpx;
}
.section-header__left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.section-header__title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}
.section-header__right {
  display: flex;
  align-items: center;
  gap: 6rpx;
  pointer-events: auto;
}
.section-header__link {
  font-size: 24rpx;
  color: var(--text-sub);
  letter-spacing: 0.2rpx;
}

/* 横向滚动 */
.fav-scroll {
  width: 100%;
  white-space: nowrap;
}
.fav-list {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  padding-right: 32rpx;
}

/* 收藏卡片 */
.fav-card {
  display: inline-flex;
  flex-direction: column;
  width: 240rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: var(--radius-card);
  overflow: hidden;
  box-shadow: var(--shadow-ios);
  flex-shrink: 0;
}
.fav-card__top {
  position: relative;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.fav-card__icon {
  font-size: 48rpx;
}
.fav-card__heart {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
}
.fav-card__body {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.fav-card__title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-main);
  letter-spacing: 0.2rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.fav-card__tag {
  display: inline-flex;
  align-self: flex-start;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-tag);
  font-size: 22rpx;
  font-weight: 400;
  letter-spacing: 0.2rpx;
}
.fav-card__date {
  font-size: 22rpx;
  color: var(--text-assist);
  letter-spacing: 0.2rpx;
}

/* ============ 统计条 ============ */
.stats-row {
  display: flex;
  align-items: center;
  margin-top: 32rpx;
  padding: 36rpx 20rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-ios);
}
.stats-cell { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.stats-cell__num {
  font-size: 52rpx;
  font-weight: 300;
  color: var(--text-main);
  letter-spacing: 0;
  line-height: 1;
  font-feature-settings: "tnum";
}
.stats-cell__label {
  font-size: 24rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
  font-weight: 400;
}
.stats-cell__divider { width: 1rpx; height: 56rpx; background: var(--line-soft); }

/* ============ 双列卡 ============ */
.duo-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 20rpx;
}
.duo-cell {
  position: relative;
  display: flex;
  flex-direction: column;
  min-height: 280rpx;
  padding: 28rpx 24rpx;
  border: 1rpx solid var(--card-border);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-ios);
  box-sizing: border-box;
  overflow: hidden;
}

/* 左侧天气卡 */
.duo-cell--welcome {
  background: var(--card-bg);
  justify-content: flex-start;
}
.duo-cell__row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 20rpx; }
.duo-cell__temp {
  font-size: 40rpx; font-weight: 400;
  color: var(--text-main); line-height: 1; letter-spacing: 0;
}
.duo-cell__greeting {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
  line-height: 1.3;
}
.duo-cell__name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
  line-height: 1.3;
  margin-bottom: 16rpx;
}
.duo-cell__sub {
  font-size: 24rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

/* 右侧 AI 卡 */
.duo-cell--ai {
  position: relative;
  background: linear-gradient(180deg, #E8D5C4 0%, #D4C4B0 100%);
  border-color: rgba(212, 163, 115, 0.30);
  justify-content: center;
  align-items: center;
  padding-top: 32rpx;
  padding-bottom: 32rpx;
}
.duo-cell__ai-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, #E8D5C4 0%, #D4C4B0 100%);
  z-index: 0;
}
.duo-cell__ai-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.duo-cell__ai-title {
  font-size: 32rpx; font-weight: 600;
  color: #4A403A; letter-spacing: 0.5rpx;
}
.duo-cell__ai-sub {
  font-size: 24rpx;
  color: rgba(74, 64, 58, 0.65); letter-spacing: 0.3rpx;
}
.duo-cell__ai-btn {
  margin-top: 16rpx;
  padding: 16rpx 52rpx;
  background: rgba(255, 255, 255, 0.70);
  border: 1rpx solid rgba(255, 255, 255, 0.50);
  border-radius: var(--radius-btn);
  font-size: 28rpx;
  font-weight: 500;
  color: #4A403A;
  letter-spacing: 0.5rpx;
  backdrop-filter: blur(8rpx);
}

/* ============ 标准化 CSS 线条图标库 ============ */
.ic { position: relative; display: inline-block; vertical-align: middle; }

/* 太阳 */
.ic-sun { width: 40rpx; height: 40rpx; display: inline-flex; align-items: center; justify-content: center; }
.ic-sun__core {
  width: 16rpx; height: 16rpx;
  border-radius: 50%;
  border: 2rpx solid var(--icon-stroke);
  background: transparent;
  box-sizing: border-box;
  box-shadow:
     0      -14rpx 0 -6rpx var(--icon-stroke),
     0       14rpx 0 -6rpx var(--icon-stroke),
    -14rpx   0     0 -6rpx var(--icon-stroke),
     14rpx   0     0 -6rpx var(--icon-stroke),
    -10rpx -10rpx  0 -7rpx var(--icon-stroke),
     10rpx -10rpx  0 -7rpx var(--icon-stroke),
    -10rpx  10rpx  0 -7rpx var(--icon-stroke),
     10rpx  10rpx  0 -7rpx var(--icon-stroke);
}
.ic-sun--sm { width: 32rpx; height: 32rpx; }
.ic-sun--sm .ic-sun__core {
  width: 12rpx; height: 12rpx;
  border-width: 1.5rpx;
  box-shadow:
     0      -12rpx 0 -5rpx var(--icon-stroke),
     0       12rpx 0 -5rpx var(--icon-stroke),
    -12rpx   0     0 -5rpx var(--icon-stroke),
     12rpx   0     0 -5rpx var(--icon-stroke),
    -8rpx -8rpx  0 -6rpx var(--icon-stroke),
     8rpx -8rpx  0 -6rpx var(--icon-stroke),
    -8rpx  8rpx  0 -6rpx var(--icon-stroke),
     8rpx  8rpx  0 -6rpx var(--icon-stroke);
}

/* 月亮 */
.ic-moon { width: 32rpx; height: 32rpx; position: relative; display: inline-block; }
.ic-moon__shape {
  position: absolute; inset: 0;
  border-radius: 50%;
  background: var(--icon-stroke);
  overflow: hidden;
}
.ic-moon__shape::after {
  content: ''; position: absolute;
  top: -4rpx; right: -10rpx;
  width: 26rpx; height: 26rpx;
  border-radius: 50%;
  background: var(--surface-elevated);
}
.ic-moon--sm { width: 28rpx; height: 28rpx; }
.ic-moon--sm .ic-moon__shape::after {
  top: -3rpx; right: -8rpx;
  width: 22rpx; height: 22rpx;
}

/* 云 */
.ic-cloud { width: 40rpx; height: 40rpx; position: relative; display: inline-block; }
.ic-cloud__body {
  position: absolute;
  top: 8rpx; left: 4rpx;
  width: 22rpx; height: 22rpx;
  border-radius: 50%;
  background: var(--icon-stroke);
}
.ic-cloud__base {
  position: absolute;
  bottom: 8rpx; left: 2rpx;
  width: 28rpx; height: 12rpx;
  border-radius: 6rpx;
  background: var(--icon-stroke);
}
.ic-cloud--sm { width: 32rpx; height: 32rpx; }
.ic-cloud--sm .ic-cloud__body { top: 6rpx; left: 3rpx; width: 18rpx; height: 18rpx; }
.ic-cloud--sm .ic-cloud__base { bottom: 6rpx; left: 1rpx; width: 22rpx; height: 10rpx; border-radius: 5rpx; }

/* 雨 */
.ic-rain { width: 40rpx; height: 40rpx; position: relative; display: inline-block; }
.ic-rain__cloud {
  position: absolute;
  top: 2rpx; left: 2rpx;
  width: 28rpx; height: 18rpx;
  border-radius: 9rpx;
  background: var(--icon-stroke);
}
.ic-rain__cloud::before {
  content: ''; position: absolute;
  top: -6rpx; left: 4rpx;
  width: 14rpx; height: 14rpx;
  border-radius: 50%;
  background: var(--icon-stroke);
}
.ic-rain__drop {
  position: absolute;
  width: 2rpx; height: 6rpx;
  background: var(--icon-stroke);
  border-radius: 1rpx;
}
.ic-rain__drop--1 { bottom: 4rpx; left: 8rpx; }
.ic-rain__drop--2 { bottom: 2rpx; left: 14rpx; }
.ic-rain__drop--3 { bottom: 5rpx; left: 20rpx; }
.ic-rain--sm { width: 32rpx; height: 32rpx; }
.ic-rain--sm .ic-rain__cloud { top: 1rpx; left: 1rpx; width: 22rpx; height: 14rpx; border-radius: 7rpx; }
.ic-rain--sm .ic-rain__cloud::before { top: -5rpx; left: 3rpx; width: 11rpx; height: 11rpx; }
.ic-rain--sm .ic-rain__drop { width: 1.5rpx; height: 5rpx; }
.ic-rain--sm .ic-rain__drop--1 { bottom: 3rpx; left: 6rpx; }
.ic-rain--sm .ic-rain__drop--2 { bottom: 1rpx; left: 11rpx; }
.ic-rain--sm .ic-rain__drop--3 { bottom: 4rpx; left: 16rpx; }

/* 雪 */
.ic-snow { width: 40rpx; height: 40rpx; position: relative; display: inline-block; }
.ic-snow__cloud {
  position: absolute;
  top: 2rpx; left: 2rpx;
  width: 28rpx; height: 18rpx;
  border-radius: 9rpx;
  background: var(--icon-stroke);
}
.ic-snow__cloud::before {
  content: ''; position: absolute;
  top: -6rpx; left: 4rpx;
  width: 14rpx; height: 14rpx;
  border-radius: 50%;
  background: var(--icon-stroke);
}
.ic-snow__flake {
  position: absolute;
  width: 4rpx; height: 4rpx;
  border-radius: 50%;
  background: var(--icon-stroke);
}
.ic-snow__flake--1 { bottom: 4rpx; left: 8rpx; }
.ic-snow__flake--2 { bottom: 2rpx; left: 14rpx; }
.ic-snow__flake--3 { bottom: 5rpx; left: 20rpx; }
.ic-snow--sm { width: 32rpx; height: 32rpx; }
.ic-snow--sm .ic-snow__cloud { top: 1rpx; left: 1rpx; width: 22rpx; height: 14rpx; border-radius: 7rpx; }
.ic-snow--sm .ic-snow__cloud::before { top: -5rpx; left: 3rpx; width: 11rpx; height: 11rpx; }
.ic-snow--sm .ic-snow__flake { width: 3rpx; height: 3rpx; }
.ic-snow--sm .ic-snow__flake--1 { bottom: 3rpx; left: 6rpx; }
.ic-snow--sm .ic-snow__flake--2 { bottom: 1rpx; left: 11rpx; }
.ic-snow--sm .ic-snow__flake--3 { bottom: 4rpx; left: 16rpx; }

/* 心形图标 */
.ic-heart { width: 28rpx; height: 28rpx; position: relative; display: inline-block; }
.ic-heart__shape {
  position: absolute;
  inset: 0;
  background: var(--color-pink, #E8B4B4);
  clip-path: path('M14 24 C14 24, 2 16, 2 8 C2 4, 5 1, 9 1 C11.5 1, 13.2 2.3, 14 4 C14.8 2.3, 16.5 1, 19 1 C23 1, 26 4, 26 8 C26 16, 14 24, 14 24Z');
}

/* 小心形 */
.ic-heart--small { width: 20rpx; height: 20rpx; position: relative; display: inline-block; }
.ic-heart--small .ic-heart__shape {
  position: absolute;
  inset: 0;
  background: var(--color-pink, #E8B4B4);
  clip-path: path('M10 17 C10 17, 1.5 11.5, 1.5 5.5 C1.5 2.5, 3.8 0.5, 6.5 0.5 C8.2 0.5, 9.4 1.5, 10 2.7 C10.6 1.5, 11.8 0.5, 13.5 0.5 C16.2 0.5, 18.5 2.5, 18.5 5.5 C18.5 11.5, 10 17, 10 17Z');
}

/* 右箭头 */
.ic-chevron-right {
  width: 16rpx;
  height: 16rpx;
  border-top: 2rpx solid var(--text-sub);
  border-right: 2rpx solid var(--text-sub);
  transform: rotate(45deg);
}

/* 更多按钮 */
.ic-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.ic-more__dot {
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: var(--text-sub);
}

/* ============ 深色主题覆盖 ============ */
.page-root.theme-dark .duo-cell--ai {
  background: linear-gradient(180deg, #3A3634 0%, #2E2C2A 100%);
  border-color: rgba(200, 168, 128, 0.20);
}
.page-root.theme-dark .duo-cell__ai-bg {
  background: linear-gradient(180deg, #3A3634 0%, #2E2C2A 100%);
}
.page-root.theme-dark .duo-cell__ai-title {
  color: #E8E0D8;
}
.page-root.theme-dark .duo-cell__ai-sub {
  color: rgba(232, 224, 216, 0.60);
}
.page-root.theme-dark .duo-cell__ai-btn {
  background: rgba(255, 255, 255, 0.10);
  border-color: rgba(255, 255, 255, 0.15);
  color: #E8E0D8;
}
.page-root.theme-dark .ic-moon__shape::after { background: var(--surface-elevated); }

.safe-bottom { height: calc(env(safe-area-inset-bottom) + 20rpx); }

.tap-scale:active { transform: scale(0.97); transition: transform 0.15s ease; }
