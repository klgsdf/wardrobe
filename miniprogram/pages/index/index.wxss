/* pages/index/index.wxss - Ins 极简风电子衣柜（白·粉·蓝配色） */

/* ============ 页面根 ============ */
.page-root {
  width: 100%;
  min-height: 100vh;
  background: var(--bg-page);
}
.nav-pad { width: 100%; }

/* ============ 顶部导航栏（极简） ============ */
.nav-actions {
  position: fixed;
  left: 32rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  z-index: 100;
  pointer-events: none;
}
.nav-actions > .wardrobe-name,
.nav-actions > .icon-btn { pointer-events: auto; }
.nav-actions__spacer { flex: 1; }

.page-body {
  box-sizing: border-box;
  padding: 0 32rpx 32rpx;
}

/* ============ 衣柜名字（极简文字按钮） ============ */
.wardrobe-name {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 0;
  background: transparent;
  border: none;
  box-shadow: none;
  box-sizing: border-box;
}
.wardrobe-name__text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
  line-height: 1;
}
.wardrobe-name__chev {
  width: 8rpx;
  height: 8rpx;
  border-right: 1.5rpx solid var(--text-sub);
  border-bottom: 1.5rpx solid var(--text-sub);
  transform: rotate(45deg);
  margin-top: -2rpx;
}

.icon-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  box-shadow: none;
  box-sizing: border-box;
}

/* ============ 主卡：极简衣柜展示区 ============ */
.wardrobe-card {
  position: relative;
  width: 100%;
  padding-top: 115%;
  border-radius: var(--radius-card-lg);
  overflow: hidden;
  margin-top: 4rpx;
  background: var(--surface-inner);
  border: 1rpx solid var(--card-border);
}

/* 场景层：极简扁平 */
.scene { position: absolute; inset: 0; }
.scene__wall {
  position: absolute; top: 0; left: 0; right: 0; height: 75%;
  background: var(--scene-wall-top);
}
.scene__floor {
  position: absolute; bottom: 0; left: 0; right: 0; height: 25%;
  background: var(--scene-floor-top);
}
.scene__skirting {
  position: absolute; left: 0; right: 0; top: 75%;
  height: 1rpx; background: var(--scene-skirting);
}
.scene__light-halo {
  display: none;
}

/* 侧边装饰点阵 - 极简细线 */
.closet-side {
  position: absolute;
  top: 28%; bottom: 35%;
  width: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  align-items: center;
  z-index: 3;
}
.closet-side--l { left: 28rpx; }
.closet-side--r { right: 28rpx; }
.closet-side__dot {
  width: 6rpx; height: 6rpx;
  border-radius: 50%;
  background: var(--glass-outline);
  border: none;
}
.page-root.theme-dark .closet-side__dot {
  background: var(--glass-outline);
}

/* ============ 极简衣柜 ============ */
.closet-art {
  position: absolute;
  top: 8%;
  bottom: 10%;
  left: 14%;
  right: 14%;
  z-index: 4;
}

/* 底部投影 - 极简 */
.closet-art__shadow {
  position: absolute;
  left: 8%; right: 8%;
  bottom: -12rpx;
  height: 32rpx;
  background: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.06) 0%, rgba(0, 0, 0, 0) 70%);
  filter: blur(8rpx);
}

/* 衣柜框体 - 扁平化，无玻璃态 */
.closet-art__frame {
  position: relative;
  width: 100%; height: 100%;
  background: var(--glass-panel);
  border: 1rpx solid var(--glass-edge);
  border-radius: var(--radius-sm);
  box-sizing: border-box;
  overflow: hidden;
}

.page-root.theme-dark .closet-art__frame {
  border-color: var(--glass-edge);
}

/* 玻璃高光 - 移除 */
.closet-art__gloss {
  display: none;
}

/* ---- LED 灯带 - 移除 ---- */
.closet-art__led {
  display: none;
}

/* ---- 隔板 - 极简细线 ---- */
.closet-art__shelf {
  position: absolute;
  left: 8rpx; right: 8rpx;
  height: 1rpx;
  background: var(--glass-outline);
}
.closet-art__shelf--top { top: 22%; }
.closet-art__shelf--mid { top: 24%; opacity: 0.3; }

/* ---- 顶部折叠物 ---- */
.closet-art__folds {
  position: absolute;
  top: 10%; left: 18%; right: 18%; height: 11%;
  display: flex; align-items: flex-end; justify-content: space-around;
  gap: 6rpx;
}
.fold {
  flex: 1;
  background: var(--surface-elevated);
  border: 1rpx solid var(--glass-outline);
  border-radius: var(--radius-xs);
}
.fold--a { height: 70%; }
.fold--b { height: 85%; }
.fold--c { height: 60%; }
.page-root.theme-dark .fold { background: var(--surface-elevated); border-color: var(--glass-outline); }

/* ---- 左半柜体：挂衣区 ---- */
.closet-art__left {
  position: absolute;
  top: 28%; bottom: 30%;
  left: 0; width: 52%;
  padding: 0 12rpx;
  box-sizing: border-box;
}
.hang-rod {
  position: absolute;
  left: 12rpx; right: 12rpx;
  top: 14rpx;
  height: 2rpx;
  background: var(--glass-outline);
  border-radius: 1rpx;
}
.hang-rod--double,
.hang-rod--extendable { top: 10rpx; }
.hang-rod--lower { top: 55%; }
.hang-rod--extendable::after {
  content: ''; position: absolute; right: -2rpx; top: -2rpx;
  width: 6rpx; height: 7rpx;
  border-radius: 50%;
  background: var(--color-primary);
}
.closet-art__hang {
  position: absolute;
  top: 24rpx; left: 0; right: 0; bottom: 6rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-around;
  padding: 0 6rpx;
}
.closet-art__hang .ic-shirt,
.closet-art__hang .ic-dress,
.closet-art__hang .ic-coat {
  transform: scale(0.55);
  transform-origin: top center;
}

/* ---- 右半柜体：推拉门 ---- */
.closet-art__right {
  position: absolute;
  top: 28%; bottom: 30%;
  right: 0; width: 48%;
  padding: 0 10rpx;
  box-sizing: border-box;
}
.door-panel {
  position: relative;
  width: 100%; height: 100%;
  background: var(--surface-elevated);
  border: 1rpx solid var(--glass-outline);
  border-radius: var(--radius-xs);
  overflow: hidden;
}
.page-root.theme-dark .door-panel {
  background: var(--surface-elevated);
}
.door-handle {
  position: absolute;
  top: 50%; left: -4rpx;
  width: 4rpx; height: 32rpx;
  margin-top: -16rpx;
  background: var(--color-primary);
  border-radius: 2rpx;
}

/* 门款：推拉门圆点 */
.door-dots {
  position: absolute;
  inset: 14rpx 10rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-auto-rows: 1fr;
  gap: 4rpx;
  place-items: center;
}
.door-dots__dot {
  width: 5rpx; height: 5rpx;
  border-radius: 50%;
  background: var(--glass-outline);
}
.page-root.theme-dark .door-dots__dot { background: var(--glass-outline); }

/* 门款：百叶门 */
.door-louvers {
  position: absolute;
  inset: 14rpx 8rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
}
.door-louvers__bar {
  height: 2rpx;
  background: var(--glass-outline);
  border-radius: 1rpx;
  opacity: 0.4;
}

/* 门款：平开门 */
.door-swing {
  position: absolute;
  top: 10%; bottom: 10%; left: 50%;
  width: 1rpx;
  background: var(--glass-outline);
  opacity: 0.3;
}

/* 门款：镜面门 */
.door-mirror {
  position: absolute;
  inset: 8rpx;
  background: var(--surface-elevated);
  border-radius: var(--radius-xs);
}
.page-root.theme-dark .door-mirror {
  background: var(--surface-elevated);
}

/* 无门开放式 */
.closet-art__right.door--open .door-panel { background: transparent; border: none; }
.closet-art__right.door--open .door-handle { display: none; }

/* ---- 底部抽屉 ---- */
.closet-art__drawers {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  height: 28%;
  display: flex;
  flex-direction: column;
  padding: 0 8rpx 8rpx;
  gap: 4rpx;
  box-sizing: border-box;
}
.drawer {
  flex: 1;
  position: relative;
  background: var(--surface-elevated);
  border: 1rpx solid var(--glass-outline);
  border-radius: var(--radius-xs);
}
.page-root.theme-dark .drawer {
  background: var(--surface-elevated);
}
.drawer__notch {
  position: absolute;
  top: 50%; left: 50%;
  width: 36rpx; height: 3rpx;
  margin-left: -18rpx;
  margin-top: -1.5rpx;
  background: var(--glass-outline);
  border-radius: 2rpx;
  opacity: 0.5;
}

/* 4 抽：第一抽更矮 */
.drawers--4 .drawer:first-child { flex: 0.6; }

/* ============ 右下角 DIY 提示（极简 pill） ============ */
.closet-tip {
  position: absolute;
  right: 24rpx; bottom: 24rpx;
  z-index: 6;
  display: flex; align-items: center; gap: 8rpx;
  padding: 8rpx 18rpx;
  background: var(--surface-elevated);
  border: 1rpx solid var(--card-border);
  border-radius: var(--radius-btn);
  box-shadow: none;
}
.page-root.theme-dark .closet-tip {
  background: var(--surface-elevated);
}
.closet-tip__dot {
  width: 8rpx; height: 8rpx;
  border-radius: 50%;
  background: var(--color-primary);
}
.closet-tip__text {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
  line-height: 1;
  font-weight: 400;
}

/* ============ 渐变桥：移除 ============ */
.bridge {
  display: none;
}

/* ============ 统计条（极简） ============ */
.stats-row {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding: 32rpx 20rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: var(--radius-card);
  box-shadow: none;
}
.page-root.theme-dark .stats-row {
  background: var(--card-bg);
}
.stats-cell { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.stats-cell__num {
  font-size: 48rpx;
  font-weight: 300;
  color: var(--text-main);
  letter-spacing: 0;
  line-height: 1;
  font-feature-settings: "tnum";
}
.stats-cell__label {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.5rpx;
  font-weight: 400;
}
.stats-cell__divider { width: 1rpx; height: 48rpx; background: var(--line-soft); }

/* ============ 双列卡（极简） ============ */
.duo-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 16rpx;
}
.duo-cell {
  position: relative;
  display: flex;
  flex-direction: column;
  min-height: 220rpx;
  padding: 28rpx 24rpx;
  border: 1rpx solid var(--card-border);
  border-radius: var(--radius-card);
  box-shadow: none;
  box-sizing: border-box;
  overflow: hidden;
}
.duo-cell--welcome { background: var(--card-bg); }
.duo-cell__row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.duo-cell__temp {
  font-size: 36rpx; font-weight: 300;
  color: var(--text-main); line-height: 1; letter-spacing: 0;
}
.duo-cell__title { font-size: 28rpx; font-weight: 400; color: var(--text-main); letter-spacing: 0.3rpx; }
.duo-cell__sub   { margin-top: 8rpx; font-size: 22rpx; color: var(--text-sub); letter-spacing: 0.3rpx; }

.duo-cell--ai {
  background: var(--ai-card-bg);
  border-color: var(--ai-card-border);
  justify-content: space-between;
}
.duo-cell__ai-halo {
  display: none;
}
.duo-cell__ai-title {
  position: relative; z-index: 1;
  margin-top: 16rpx;
  font-size: 32rpx; font-weight: 400;
  color: var(--text-main); letter-spacing: 0.3rpx;
}
.duo-cell__ai-sub {
  position: relative; z-index: 1;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-sub); letter-spacing: 0.3rpx;
}
.duo-cell__ai-arrow {
  position: absolute; right: 20rpx; bottom: 20rpx;
  width: 48rpx; height: 48rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--color-primary);
  border-radius: 50%;
  box-shadow: none;
  z-index: 2;
}

/* 粉色点缀元素 */
.duo-cell__pink-dot {
  width: 8rpx; height: 8rpx;
  border-radius: 50%;
  background: var(--color-pink, #F8BBD9);
}

/* 蓝色大卡片风格（参考图顶部横幅） */
.card-blue {
  background: var(--color-primary);
  color: #FFFFFF;
  border: none;
}
.card-blue .duo-cell__title,
.card-blue .duo-cell__temp,
.card-blue .duo-cell__sub {
  color: #FFFFFF;
}

/* 粉色图标背景 */
.icon-pink-bg {
  width: 80rpx; height: 80rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--color-pink-light, #FCE4EC);
  border-radius: 50%;
}

/* 蓝色图标背景 */
.icon-blue-bg {
  width: 80rpx; height: 80rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--color-primary-light, #6BA5E7);
  border-radius: 50%;
}

/* ============ 标准化 CSS 线条图标库（极简细线） ============ */
.ic { position: relative; display: inline-block; vertical-align: middle; }

/* 太阳 */
.ic-sun { width: 40rpx; height: 40rpx; display: inline-flex; align-items: center; justify-content: center; }
.ic-sun__core {
  width: 16rpx; height: 16rpx;
  border-radius: 50%;
  border: 2rpx solid var(--icon-stroke);
  background: transparent;
  box-sizing: border-box;
  box-shadow:
     0      -14rpx 0 -6rpx var(--icon-stroke),
     0       14rpx 0 -6rpx var(--icon-stroke),
    -14rpx   0     0 -6rpx var(--icon-stroke),
     14rpx   0     0 -6rpx var(--icon-stroke),
    -10rpx -10rpx  0 -7rpx var(--icon-stroke),
     10rpx -10rpx  0 -7rpx var(--icon-stroke),
    -10rpx  10rpx  0 -7rpx var(--icon-stroke),
     10rpx  10rpx  0 -7rpx var(--icon-stroke);
}
.ic-sun--sm { width: 32rpx; height: 32rpx; }
.ic-sun--sm .ic-sun__core {
  width: 12rpx; height: 12rpx;
  border-width: 1.5rpx;
  box-shadow:
     0      -12rpx 0 -5rpx var(--icon-stroke),
     0       12rpx 0 -5rpx var(--icon-stroke),
    -12rpx   0     0 -5rpx var(--icon-stroke),
     12rpx   0     0 -5rpx var(--icon-stroke),
    -8rpx -8rpx  0 -6rpx var(--icon-stroke),
     8rpx -8rpx  0 -6rpx var(--icon-stroke),
    -8rpx  8rpx  0 -6rpx var(--icon-stroke),
     8rpx  8rpx  0 -6rpx var(--icon-stroke);
}

/* 月亮 */
.ic-moon { width: 32rpx; height: 32rpx; position: relative; display: inline-block; }
.ic-moon__shape {
  position: absolute; inset: 0;
  border-radius: 50%;
  background: var(--icon-stroke);
  overflow: hidden;
}
.ic-moon__shape::after {
  content: ''; position: absolute;
  top: -4rpx; right: -10rpx;
  width: 26rpx; height: 26rpx;
  border-radius: 50%;
  background: var(--surface-elevated);
}

/* 火花 */
.ic-sparkle { width: 36rpx; height: 36rpx; position: relative; display: inline-block; }
.ic-sparkle__big,
.ic-sparkle__small {
  position: absolute;
  background: var(--text-main);
  clip-path: polygon(50% 0, 58% 42%, 100% 50%, 58% 58%, 50% 100%, 42% 58%, 0 50%, 42% 42%);
}
.ic-sparkle__big   { top: 2rpx;  left: 0;     width: 24rpx; height: 24rpx; }
.ic-sparkle__small { bottom: 2rpx; right: 2rpx; width: 14rpx; height: 14rpx; opacity: 0.6; }

/* 右箭头 */
.ic-arrow-right { width: 18rpx; height: 18rpx; position: relative; }
.ic-arrow-right::before {
  content: ''; position: absolute;
  top: 50%; left: 0;
  width: 14rpx; height: 2rpx;
  background: #FFFFFF;
  margin-top: -1rpx;
  border-radius: 1rpx;
}
.ic-arrow-right::after {
  content: ''; position: absolute;
  top: 50%; right: 2rpx;
  width: 8rpx; height: 8rpx;
  border-top: 2rpx solid #FFFFFF;
  border-right: 2rpx solid #FFFFFF;
  transform: rotate(45deg);
  margin-top: -4rpx;
}

/* 连衣裙 */
.ic-dress { position: relative; width: 72rpx; height: 100rpx; }
.ic-dress__hanger {
  position: absolute; top: 0; left: 50%;
  width: 30rpx; height: 14rpx;
  margin-left: -15rpx;
  border: 1.5rpx solid var(--icon-stroke);
  border-bottom: 0;
  border-top-left-radius: 14rpx;
  border-top-right-radius: 14rpx;
}
.ic-dress__hanger::after {
  content: ''; position: absolute; top: 100%; left: 50%;
  width: 1.5rpx; height: 8rpx; background: var(--icon-stroke);
  margin-left: -0.75rpx;
}
.ic-dress__body {
  position: absolute; top: 20rpx; left: 50%;
  width: 60rpx; height: 70rpx;
  margin-left: -30rpx;
  border: 1.5rpx solid var(--icon-stroke);
  background: var(--icon-fill);
  clip-path: polygon(28% 0, 72% 0, 100% 100%, 0 100%);
  border-radius: 6rpx;
}

/* 外套 */
.ic-coat { position: relative; width: 72rpx; height: 100rpx; }
.ic-coat__hanger {
  position: absolute; top: 0; left: 50%;
  width: 30rpx; height: 14rpx;
  margin-left: -15rpx;
  border: 1.5rpx solid var(--icon-stroke);
  border-bottom: 0;
  border-top-left-radius: 14rpx;
  border-top-right-radius: 14rpx;
}
.ic-coat__body {
  position: absolute; top: 18rpx; left: 50%;
  width: 60rpx; height: 78rpx;
  margin-left: -30rpx;
  border: 1.5rpx solid var(--icon-stroke);
  background: var(--icon-fill);
  border-radius: 8rpx 8rpx 4rpx 4rpx;
}
.ic-coat__lapel-l,
.ic-coat__lapel-r {
  position: absolute; top: 20rpx;
  width: 1.5rpx; height: 48rpx;
  background: var(--icon-stroke);
}
.ic-coat__lapel-l { left: 50%; margin-left: -8rpx; transform: rotate(-6deg); transform-origin: top; }
.ic-coat__lapel-r { left: 50%; margin-left:  6rpx; transform: rotate( 6deg); transform-origin: top; }
.ic-coat__belt {
  position: absolute; top: 62rpx; left: 50%;
  width: 40rpx; height: 2rpx;
  margin-left: -20rpx;
  background: var(--icon-stroke);
}

/* 衬衫 */
.ic-shirt { position: relative; width: 72rpx; height: 100rpx; }
.ic-shirt__hanger {
  position: absolute; top: 0; left: 50%;
  width: 30rpx; height: 14rpx;
  margin-left: -15rpx;
  border: 1.5rpx solid var(--icon-stroke);
  border-bottom: 0;
  border-top-left-radius: 14rpx;
  border-top-right-radius: 14rpx;
}
.ic-shirt__body {
  position: absolute; top: 18rpx; left: 50%;
  width: 60rpx; height: 70rpx;
  margin-left: -30rpx;
  border: 1.5rpx solid var(--icon-stroke);
  background: var(--icon-fill);
  border-radius: 6rpx;
}
.ic-shirt__collar-l,
.ic-shirt__collar-r {
  position: absolute; top: 18rpx;
  width: 0; height: 0;
  border-top: 14rpx solid var(--icon-stroke);
}
.ic-shirt__collar-l { left: 50%; margin-left: -12rpx; border-right: 8rpx solid transparent; }
.ic-shirt__collar-r { left: 50%; margin-left:  4rpx;  border-left:  8rpx solid transparent; }
.ic-shirt__tie {
  position: absolute; top: 30rpx; left: 50%;
  width: 8rpx; height: 36rpx;
  margin-left: -4rpx;
  background: var(--icon-stroke);
  clip-path: polygon(30% 0, 70% 0, 100% 100%, 50% 100%, 0 100%);
}

/* ============ 深色主题覆盖 ============ */
.page-root.theme-dark .duo-cell__ai-arrow {
  background: var(--color-primary-deep);
}
.page-root.theme-dark .ic-arrow-right::before { background: var(--text-main); }
.page-root.theme-dark .ic-arrow-right::after {
  border-top-color: var(--text-main);
  border-right-color: var(--text-main);
}
.page-root.theme-dark .ic-moon__shape::after { background: var(--bg-start); }

.safe-bottom { height: calc(env(safe-area-inset-bottom) + 100rpx); }

.tap-scale:active { transform: scale(0.97); transition: transform 0.15s ease; }
