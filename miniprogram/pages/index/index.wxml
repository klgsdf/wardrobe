<!--pages/index/index.wxml - 首页（焦糖米黄风 · 参考图布局）-->
<view class="page-root {{isDark ? 'theme-dark' : ''}}">

  <!-- 导航栏：左侧衣柜名字 + 右侧日夜切换 -->
  <view class="nav-actions"
        style="top: {{menuBtnTop}}px; height: {{menuBtnHeight}}px; right: {{navActionsRight}}px;">
    <view class="wardrobe-name tap-scale" bindtap="onEditName"
          style="height: {{menuBtnHeight}}px;">
      <text class="wardrobe-name__text">{{wardrobeName}}</text>
      <view class="wardrobe-name__chev"></view>
    </view>
    <view class="nav-actions__spacer"></view>
    <view class="icon-btn tap-scale" bindtap="onToggleTheme"
          style="width: {{menuBtnHeight}}px; height: {{menuBtnHeight}}px;">
      <view wx:if="{{isDark}}" class="ic ic-sun">
        <view class="ic-sun__core"></view>
      </view>
      <view wx:else class="ic ic-moon">
        <view class="ic-moon__shape"></view>
      </view>
    </view>
    <view class="icon-btn icon-btn--more tap-scale"
          style="width: {{menuBtnHeight}}px; height: {{menuBtnHeight}}px;">
      <view class="ic-more">
        <view class="ic-more__dot"></view>
        <view class="ic-more__dot"></view>
        <view class="ic-more__dot"></view>
      </view>
    </view>
  </view>

  <view class="page-body">
    <!-- 状态栏 + 导航栏占位 -->
    <view class="nav-pad" style="height: {{navPadHeight}}px; width: 100%;"></view>

    <!-- ===== 收藏的搭配 ===== -->
    <view class="section-header">
      <view class="section-header__left">
        <view class="ic-heart">
          <view class="ic-heart__shape"></view>
        </view>
        <text class="section-header__title">收藏的搭配</text>
      </view>
      <view class="section-header__right tap-scale" bindtap="onViewAllFavorites">
        <text class="section-header__link">查看全部</text>
        <view class="ic-chevron-right"></view>
      </view>
    </view>

    <!-- 横向滚动收藏卡片 -->
    <scroll-view class="fav-scroll" scroll-x="true" show-scrollbar="false">
      <view class="fav-list">
        <view wx:for="{{favorites}}" wx:key="id" class="fav-card tap-scale" bindtap="onFavoriteTap" data-id="{{item.id}}">
          <view class="fav-card__top" style="background: {{item.bgColor}};">
            <view class="fav-card__icon">{{item.icon}}</view>
            <view class="fav-card__heart">
              <view class="ic-heart--small">
                <view class="ic-heart__shape"></view>
              </view>
            </view>
          </view>
          <view class="fav-card__body">
            <text class="fav-card__title">{{item.title}}</text>
            <view class="fav-card__tag" style="background: {{item.tagBg}}; color: {{item.tagColor}};">{{item.tag}}</view>
            <text class="fav-card__date">{{item.date}}</text>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- ===== 统计条 ===== -->
    <view class="stats-row">
      <view class="stats-cell">
        <view class="stats-cell__num">{{stats.total}}</view>
        <view class="stats-cell__label">衣物数量</view>
      </view>
      <view class="stats-cell__divider"></view>
      <view class="stats-cell">
        <view class="stats-cell__num">{{stats.worn}}</view>
        <view class="stats-cell__label">本月穿过</view>
      </view>
      <view class="stats-cell__divider"></view>
      <view class="stats-cell">
        <view class="stats-cell__num">{{stats.unused}}</view>
        <view class="stats-cell__label">闲置数量</view>
      </view>
    </view>

    <!-- ===== 双列 Widget：左 天气  右 AI 推荐 ===== -->
    <view class="duo-grid">
      <view class="duo-cell duo-cell--welcome tap-scale" bindtap="onWeatherTap">
        <view class="duo-cell__row">
          <!-- 天气图标根据 type 动态切换 -->
          <view wx:if="{{weather.type === 'sunny'}}" class="ic ic-sun ic-sun--sm"><view class="ic-sun__core"></view></view>
          <view wx:elif="{{weather.type === 'night'}}" class="ic ic-moon ic-moon--sm"><view class="ic-moon__shape"></view></view>
          <view wx:elif="{{weather.type === 'cloudy'}}" class="ic ic-cloud ic-cloud--sm"><view class="ic-cloud__body"></view><view class="ic-cloud__base"></view></view>
          <view wx:elif="{{weather.type === 'rainy'}}" class="ic ic-rain ic-rain--sm"><view class="ic-rain__cloud"></view><view class="ic-rain__drop ic-rain__drop--1"></view><view class="ic-rain__drop ic-rain__drop--2"></view><view class="ic-rain__drop ic-rain__drop--3"></view></view>
          <view wx:elif="{{weather.type === 'snowy'}}" class="ic ic-snow ic-snow--sm"><view class="ic-snow__cloud"></view><view class="ic-snow__flake ic-snow__flake--1"></view><view class="ic-snow__flake ic-snow__flake--2"></view><view class="ic-snow__flake ic-snow__flake--3"></view></view>
          <text class="duo-cell__temp">{{weather.temp}}</text>
        </view>
        <view class="duo-cell__greeting">{{greeting}}，</view>
        <view class="duo-cell__name">{{nickName}}</view>
        <view class="duo-cell__sub">{{weather.city}} · {{weather.desc}}</view>
      </view>

      <view class="duo-cell duo-cell--ai tap-scale" bindtap="onAiRecommend">
        <view class="duo-cell__ai-bg"></view>
        <view class="duo-cell__ai-content">
          <view class="duo-cell__ai-title">AI 智能搭配</view>
          <view class="duo-cell__ai-sub">你的私人穿搭顾问</view>
          <view class="duo-cell__ai-btn">开始搭配</view>
        </view>
      </view>
    </view>

    <view class="safe-bottom"></view>
  </view>
</view>
