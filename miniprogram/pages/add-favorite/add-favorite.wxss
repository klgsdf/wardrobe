/* pages/add-favorite/add-favorite.wxss - 添加收藏页面（焦糖米黄风） */

.page-root {
  width: 100%;
  min-height: 100vh;
  background: var(--bg-page);
  box-sizing: border-box;
}

.nav-pad { width: 100%; }

/* ============ 自定义导航栏 ============ */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  z-index: 100;
  background: var(--nav-bg);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  box-sizing: border-box;
}

.nav-bar__left {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 120rpx;
}

.nav-bar__title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  letter-spacing: 0.5rpx;
}

.nav-bar__right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  min-width: 120rpx;
}

/* 返回箭头图标 */
.ic-back {
  position: relative;
  width: 24rpx;
  height: 24rpx;
}
.ic-back__line {
  position: absolute;
  top: 50%;
  left: 0;
  width: 18rpx;
  height: 2.5rpx;
  background: var(--color-primary);
  border-radius: 1.5rpx;
  transform: translateY(-50%);
}
.ic-back__arrow {
  position: absolute;
  top: 50%;
  left: 0;
  width: 10rpx;
  height: 10rpx;
  border-top: 2.5rpx solid var(--color-primary);
  border-left: 2.5rpx solid var(--color-primary);
  transform: translateY(-50%) rotate(-45deg);
}

.icon-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  box-shadow: none;
}

/* 太阳/月亮图标 */
.ic { position: relative; display: inline-block; vertical-align: middle; }

.ic-sun { width: 32rpx; height: 32rpx; display: inline-flex; align-items: center; justify-content: center; }
.ic-sun__core {
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  border: 2rpx solid var(--icon-stroke);
  background: transparent;
  box-sizing: border-box;
  box-shadow:
     0      -12rpx 0 -5rpx var(--icon-stroke),
     0       12rpx 0 -5rpx var(--icon-stroke),
    -12rpx   0     0 -5rpx var(--icon-stroke),
     12rpx   0     0 -5rpx var(--icon-stroke),
    -8rpx -8rpx  0 -6rpx var(--icon-stroke),
     8rpx -8rpx  0 -6rpx var(--icon-stroke),
    -8rpx  8rpx  0 -6rpx var(--icon-stroke),
     8rpx  8rpx  0 -6rpx var(--icon-stroke);
}

.ic-moon { width: 32rpx; height: 32rpx; position: relative; display: inline-block; }
.ic-moon__shape {
  position: absolute; inset: 0;
  border-radius: 50%;
  background: var(--icon-stroke);
  overflow: hidden;
}
.ic-moon__shape::after {
  content: ''; position: absolute;
  top: -4rpx; right: -10rpx;
  width: 26rpx; height: 26rpx;
  border-radius: 50%;
  background: var(--surface-elevated);
}
.page-root.theme-dark .ic-moon__shape::after { background: var(--bg-start); }

/* ============ 页面主体 ============ */
.page-body {
  padding: 0 28rpx 32rpx;
  box-sizing: border-box;
}

/* ============ 通用卡片 ============ */
.section-card {
  margin-top: 20rpx;
  padding: 28rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: var(--radius-card);
  box-sizing: border-box;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
  letter-spacing: 0.5rpx;
}

.section-sub {
  font-size: 24rpx;
  color: var(--text-assist);
}

/* ============ 照片上传区 ============ */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--surface-inner);
}

.image-item__img {
  width: 100%;
  height: 100%;
}

.image-item__remove {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.45);
  border-radius: 50%;
}

.ic-close-sm {
  position: relative;
  width: 14rpx;
  height: 14rpx;
}
.ic-close-sm__l1,
.ic-close-sm__l2 {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 12rpx;
  height: 2rpx;
  background: #FFFFFF;
  border-radius: 1rpx;
}
.ic-close-sm__l1 { transform: translate(-50%, -50%) rotate(45deg); }
.ic-close-sm__l2 { transform: translate(-50%, -50%) rotate(-45deg); }

.image-add {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: var(--surface-inner);
  border: 2rpx dashed var(--text-assist);
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}

.image-add__icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 相机图标 */
.ic-camera { position: relative; width: 40rpx; height: 36rpx; }
.ic-camera__body {
  position: absolute; inset: 0;
  border: 2rpx solid var(--text-assist);
  border-radius: 6rpx;
  box-sizing: border-box;
}
.ic-camera__body::before {
  content: ''; position: absolute;
  top: -6rpx; left: 50%;
  width: 12rpx; height: 6rpx;
  border: 2rpx solid var(--text-assist);
  border-bottom: none;
  border-radius: 3rpx 3rpx 0 0;
  transform: translateX(-50%);
  box-sizing: border-box;
}
.ic-camera__lens {
  position: absolute;
  top: 50%; left: 50%;
  width: 16rpx; height: 16rpx;
  border: 2rpx solid var(--text-assist);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  box-sizing: border-box;
}

.image-add__text {
  font-size: 24rpx;
  color: var(--text-assist);
  letter-spacing: 0.3rpx;
}

/* ============ 搭配名称输入 ============ */
.name-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: var(--surface-inner);
  border: 2rpx solid var(--card-border);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--text-main);
  letter-spacing: 0.5rpx;
  box-sizing: border-box;
  line-height: 84rpx;
}

.name-input__placeholder {
  color: var(--text-assist);
  font-size: 28rpx;
  line-height: 84rpx;
}

/* ============ 搭配标签 ============ */
.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 32rpx;
  background: var(--surface-inner);
  border: 2rpx solid var(--card-border);
  border-radius: var(--radius-btn);
  transition: all 0.2s ease;
}

.tag-chip text {
  font-size: 26rpx;
  color: var(--text-sub);
  font-weight: 400;
  letter-spacing: 0.3rpx;
}

.tag-chip.is-active {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.tag-chip.is-active text {
  color: #FFFFFF;
  font-weight: 500;
}

/* ============ 关联单品 ============ */
.linked-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.linked-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: var(--surface-inner);
  border: 1rpx solid var(--card-border);
  border-radius: var(--radius-sm);
}

.linked-item__icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-inner);
  border: 1rpx solid var(--card-border);
  border-radius: 50%;
  flex-shrink: 0;
}

.linked-item__icon-text {
  font-size: 22rpx;
  color: var(--text-sub);
  font-weight: 500;
  letter-spacing: 0.3rpx;
}

.linked-item__info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.linked-item__category {
  font-size: 22rpx;
  color: var(--text-assist);
  letter-spacing: 0.3rpx;
}

.linked-item__name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.linked-item__remove {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: 50%;
  flex-shrink: 0;
}

.linked-item__remove .ic-close-sm__l1,
.linked-item__remove .ic-close-sm__l2 {
  background: var(--text-assist);
}

/* 添加单品按钮 */
.add-item-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 0;
  background: var(--surface-inner);
  border: 2rpx dashed var(--text-assist);
  border-radius: var(--radius-sm);
  transition: all 0.2s ease;
}

.add-item-bar:active {
  background: var(--card-bg);
  border-color: var(--color-primary);
}

.add-item-bar:active .add-plus__h,
.add-item-bar:active .add-plus__v {
  background: var(--color-primary);
}

.add-item-bar:active .add-item-bar__text {
  color: var(--color-primary);
}

.add-item-bar__plus {
  position: relative;
  width: 28rpx;
  height: 28rpx;
}

.add-plus__h,
.add-plus__v {
  position: absolute;
  top: 50%; left: 50%;
  background: var(--text-assist);
  border-radius: 2rpx;
  transform: translate(-50%, -50%);
  transition: background 0.2s ease;
}
.add-plus__h { width: 20rpx; height: 2.5rpx; }
.add-plus__v { width: 2.5rpx; height: 20rpx; }

.add-item-bar__text {
  font-size: 26rpx;
  color: var(--text-assist);
  letter-spacing: 0.5rpx;
  transition: color 0.2s ease;
}

/* ============ 保存按钮 ============ */
.save-bar {
  margin-top: 32rpx;
  padding: 0 4rpx;
}

.save-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 26rpx 0;
  background: var(--color-primary);
  border-radius: var(--radius-btn);
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 1rpx;
  box-shadow: 0 8rpx 16rpx -4rpx rgba(212, 163, 115, 0.35);
  transition: all 0.2s ease;
}

.save-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

/* ============ 选择单品弹窗 ============ */
.overlay {
  position: fixed;
  inset: 0;
  z-index: 500;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  animation: fadeIn 0.2s ease;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.picker-sheet {
  width: 100%;
  max-height: 70vh;
  padding: 32rpx 32rpx calc(env(safe-area-inset-bottom) + 32rpx);
  background: var(--surface-elevated);
  border-top-left-radius: var(--radius-card-lg);
  border-top-right-radius: var(--radius-card-lg);
  box-sizing: border-box;
  animation: slideUp 0.28s ease;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.picker-sheet__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.picker-sheet__title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.5rpx;
}

.picker-sheet__close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-list {
  max-height: 50vh;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: var(--card-bg);
  border: 2rpx solid var(--card-border);
  border-radius: var(--radius-sm);
  transition: all 0.2s ease;
}

.picker-item:active {
  border-color: var(--color-primary);
  background: rgba(212, 163, 115, 0.05);
}

.picker-item.is-selected {
  border-color: var(--color-primary);
  background: rgba(212, 163, 115, 0.08);
}

.picker-item__check {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-inner);
  border: 2rpx solid var(--card-border);
  border-radius: 50%;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.picker-item.is-selected .picker-item__check {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

/* 勾选图标 */
.ic-check { position: relative; width: 18rpx; height: 14rpx; }
.ic-check__line1 { position: absolute; top: 55%; left: 10%; width: 8rpx; height: 2.5rpx; background: #FFFFFF; border-radius: 1rpx; transform: rotate(45deg); }
.ic-check__line2 { position: absolute; top: 48%; left: 30%; width: 14rpx; height: 2.5rpx; background: #FFFFFF; border-radius: 1rpx; transform: rotate(-45deg); }

.picker-item__info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.picker-item__name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-item__meta {
  font-size: 22rpx;
  color: var(--text-assist);
  letter-spacing: 0.3rpx;
}

.picker-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.picker-empty text {
  font-size: 26rpx;
  color: var(--text-assist);
  letter-spacing: 0.3rpx;
}

/* ============ 弹窗底部确认栏 ============ */
.picker-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--line-soft);
}

.picker-count {
  font-size: 26rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.picker-confirm {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 48rpx;
  background: var(--color-primary);
  border-radius: var(--radius-btn);
  font-size: 28rpx;
  font-weight: 500;
  color: #FFFFFF;
  letter-spacing: 0.5rpx;
  transition: all 0.2s ease;
}

.picker-confirm.is-disabled {
  opacity: 0.4;
  pointer-events: none;
}

/* ============ 安全区 ============ */
.safe-bottom { height: calc(env(safe-area-inset-bottom) + 120rpx); }

.tap-scale { transition: transform 0.15s ease; }
.tap-scale:active { transform: scale(0.97); }
