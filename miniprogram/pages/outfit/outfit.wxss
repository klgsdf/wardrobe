/* pages/outfit/outfit.wxss - 智能搭配推荐页 */

/* ===== 根容器：承载主题切换 ===== */
.page-root {
  width: 100%;
  min-height: 100vh;
  background: var(--bg-page);
  transition: background 0.4s ease;
}

/* ===== 自定义磨砂导航栏 ===== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 99;
  background: var(--nav-bg);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border-bottom: 1rpx solid var(--card-border);
}

.nav-bar__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  letter-spacing: 2rpx;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: 50%;
  box-shadow: var(--shadow-soft);
}

.nav-btn__icon {
  font-size: 30rpx;
  line-height: 1;
}

/* ===== 滚动容器 ===== */
.scroll-wrap {
  box-sizing: border-box;
  padding: 0 32rpx 40rpx;
  height: 100vh;
}

/* ===== A. AI 推荐主横幅 Hero ===== */
.hero {
  position: relative;
  margin-top: 24rpx;
  padding: 36rpx 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #7BA3C9 0%, #5B8DB8 100%);
  box-shadow: 0 16rpx 48rpx rgba(91, 141, 184, 0.30);
  overflow: hidden;
  min-height: 280rpx;
}

/* 装饰光晕 */
.hero__halo {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  filter: blur(10rpx);
  pointer-events: none;
}
.hero__halo--1 { width: 160rpx; height: 160rpx; top: -40rpx; right: -20rpx; }
.hero__halo--2 { width: 120rpx; height: 120rpx; top: 60rpx;  right: 80rpx;  opacity: 0.6; }
.hero__halo--3 { width: 80rpx;  height: 80rpx;  bottom: 20rpx; right: 40rpx; opacity: 0.4; }

.hero__content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.hero__tag {
  display: inline-flex;
  align-self: flex-start;
  padding: 6rpx 18rpx;
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: #FFFFFF;
  background: rgba(255, 255, 255, 0.22);
  border-radius: 20rpx;
  font-weight: 500;
}

.hero__title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
  line-height: 1.3;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}

.hero__sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.82);
  line-height: 1.5;
}

.hero__btn {
  display: inline-flex;
  align-self: flex-start;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
  padding: 16rpx 32rpx;
  background: #FFFFFF;
  color: #5B8DB8;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 40rpx;
  box-shadow: 0 6rpx 18rpx rgba(0, 0, 0, 0.12);
}
.hero__btn-arrow {
  font-size: 28rpx;
  line-height: 1;
  margin-top: -2rpx;
}

.hero__emoji {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  z-index: 3;
  font-size: 72rpx;
  line-height: 1;
  filter: drop-shadow(0 4rpx 12rpx rgba(0, 0, 0, 0.18));
}

/* ===== B. 天气适配条 ===== */
.weather {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
  padding: 20rpx 28rpx;
  border-radius: 28rpx;
}

.weather__icon {
  font-size: 52rpx;
  line-height: 1;
}

.weather__info {
  flex: 1;
  min-width: 0;
}

.weather__line1 {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-main);
  letter-spacing: 1rpx;
}

.weather__line2 {
  margin-top: 4rpx;
  font-size: 22rpx;
}

.weather__arrow {
  font-size: 36rpx;
  font-weight: 300;
}

/* ===== C. 今日推荐搭配 Outfit Card ===== */
.outfit-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 32rpx;
}

.outfit-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.outfit-card__tag {
  display: inline-flex;
  padding: 6rpx 18rpx;
  background: rgba(91, 141, 184, 0.12);
  color: var(--color-primary);
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  border-radius: 16rpx;
}

.outfit-card__match {
  display: inline-flex;
  align-items: baseline;
  gap: 4rpx;
  padding: 8rpx 18rpx;
  background: linear-gradient(135deg, #7BA3C9, #5B8DB8);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(91, 141, 184, 0.24);
}
.outfit-card__match-num {
  font-size: 26rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 1rpx;
}
.outfit-card__match-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.88);
}

/* 服饰网格：左右两列 */
.outfit-card__grid {
  display: flex;
  gap: 16rpx;
  height: 540rpx;
}

.outfit-card__col {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.outfit-card__col--left  { flex: 1.6; }
.outfit-card__col--right { flex: 1; }

.outfit-slot {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.42), rgba(255, 255, 255, 0.18));
  border: 1rpx solid var(--card-border);
}
.theme-dark .outfit-slot {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02));
}

.outfit-slot--lg { flex: 2; }
.outfit-slot--md { flex: 1.2; }
.outfit-slot--sm { flex: 1; }

.outfit-slot__icon {
  font-size: 72rpx;
  line-height: 1;
  filter: drop-shadow(0 4rpx 8rpx rgba(91, 141, 184, 0.20));
}
.outfit-slot--md .outfit-slot__icon { font-size: 60rpx; }
.outfit-slot--sm .outfit-slot__icon { font-size: 48rpx; }

.outfit-slot__label {
  font-size: 20rpx;
  letter-spacing: 1rpx;
}

.outfit-card__info {
  margin-top: 20rpx;
}

.outfit-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
  letter-spacing: 2rpx;
}

.outfit-card__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  font-size: 20rpx;
  color: var(--color-primary);
  background: rgba(91, 141, 184, 0.10);
  border-radius: 16rpx;
  letter-spacing: 1rpx;
}

/* ===== D. 反馈互动条 ===== */
.feedback {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-top: 24rpx;
  padding: 24rpx 16rpx;
  border-radius: 32rpx;
}

.fb-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.fb-btn__circle {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.48);
  border: 1rpx solid var(--card-border);
  border-radius: 50%;
  transition: all 0.2s ease;
}
.theme-dark .fb-btn__circle {
  background: rgba(255, 255, 255, 0.06);
}

.fb-btn__circle--primary {
  background: linear-gradient(135deg, #7BA3C9, #5B8DB8);
  border-color: transparent;
  box-shadow: 0 6rpx 18rpx rgba(91, 141, 184, 0.32);
}

.fb-btn__icon {
  font-size: 40rpx;
  line-height: 1;
}

.fb-btn__label {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 1rpx;
}

.fb-btn.is-liked .fb-btn__circle {
  background: rgba(246, 173, 85, 0.18);
  border-color: #F6AD55;
  box-shadow: 0 6rpx 16rpx rgba(246, 173, 85, 0.24);
}
.fb-btn.is-saved .fb-btn__circle {
  background: rgba(246, 173, 85, 0.18);
  border-color: #F6AD55;
}
.fb-btn.is-liked .fb-btn__label,
.fb-btn.is-saved .fb-btn__label {
  color: #F6AD55;
  font-weight: 600;
}

/* ===== E. 风格标签横滑 ===== */
.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 36rpx;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.section-head__title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
  letter-spacing: 2rpx;
}

.section-head__more {
  font-size: 22rpx;
}

.style-scroll {
  white-space: nowrap;
  padding: 4rpx 0;
}

.style-chip {
  display: inline-flex;
  align-items: center;
  height: 60rpx;
  padding: 0 28rpx;
  margin-right: 16rpx;
  font-size: 24rpx;
  color: var(--text-main);
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: 30rpx;
  box-shadow: var(--shadow-soft);
  letter-spacing: 1rpx;
}
.style-chip:last-child { margin-right: 0; }

.style-chip.is-active {
  background: linear-gradient(135deg, #7BA3C9, #5B8DB8);
  color: #FFFFFF;
  border-color: transparent;
  font-weight: 600;
  box-shadow: 0 6rpx 16rpx rgba(91, 141, 184, 0.28);
}

/* ===== F. 更多推荐（双列） ===== */
.picks-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.pick-card {
  display: flex;
  flex-direction: column;
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: 28rpx;
  box-shadow: var(--shadow-soft);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  overflow: hidden;
}

.pick-card__cover {
  position: relative;
  height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pick-card__emoji {
  font-size: 96rpx;
  line-height: 1;
  filter: drop-shadow(0 6rpx 12rpx rgba(0, 0, 0, 0.12));
}

.pick-card__heart {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.82);
  border-radius: 26rpx;
  font-size: 26rpx;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}
.pick-card__heart.is-liked {
  background: rgba(246, 173, 85, 0.22);
}

.pick-card__info {
  padding: 16rpx 20rpx 20rpx;
}

.pick-card__title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-main);
  letter-spacing: 1rpx;
}

.pick-card__match {
  margin-top: 6rpx;
  font-size: 20rpx;
  font-weight: 600;
}

/* ===== G. 最近搭配（横滑） ===== */
.recent-scroll {
  white-space: nowrap;
  padding: 4rpx 0;
}

.recent-card {
  display: inline-flex;
  flex-direction: column;
  width: 260rpx;
  margin-right: 20rpx;
  background: var(--card-bg);
  border: 1rpx solid var(--card-border);
  border-radius: 24rpx;
  box-shadow: var(--shadow-soft);
  overflow: hidden;
}
.recent-card:last-child { margin-right: 0; }

.recent-card__cover {
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.recent-card__emoji {
  font-size: 72rpx;
  line-height: 1;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.12));
}

.recent-card__info {
  padding: 14rpx 18rpx 18rpx;
}

.recent-card__date {
  font-size: 20rpx;
  letter-spacing: 1rpx;
}

.recent-card__title {
  margin-top: 4rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-main);
}

/* 底部安全区 */
.safe-bottom {
  height: calc(env(safe-area-inset-bottom) + 40rpx);
}
