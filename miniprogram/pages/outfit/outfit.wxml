<!-- pages/outfit/outfit.wxml - 智能搭配推荐页 -->
<view class="page-root {{isDark ? 'theme-dark' : ''}}">

  <!-- ===== 自定义磨砂导航栏 ===== -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar__row" style="height: {{navBarHeight}}px;">
      <view class="nav-title">智能搭配</view>
      <view class="nav-btn tap-scale" bindtap="onOpenHistory">
        <text class="nav-btn__icon">🕘</text>
      </view>
    </view>
  </view>

  <!-- ===== 滚动内容 ===== -->
  <scroll-view
    class="scroll-wrap"
    scroll-y="{{true}}"
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
    style="padding-top: {{statusBarHeight + navBarHeight}}px;"
  >

    <!-- A. AI 推荐主横幅 -->
    <view class="hero tap-scale" bindtap="onRegenerate">
      <view class="hero__halo hero__halo--1"></view>
      <view class="hero__halo hero__halo--2"></view>
      <view class="hero__halo hero__halo--3"></view>
      <view class="hero__emoji">✨</view>
      <view class="hero__content">
        <view class="hero__tag">AI 搭配</view>
        <view class="hero__title">今天穿这套，自信出门</view>
        <view class="hero__sub">基于你的 {{stats.total}} 件衣物 · 实时天气 · 今日日程</view>
        <view class="hero__btn">
          <text>立即生成</text>
          <text class="hero__btn-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- B. 天气适配条 -->
    <view class="weather glass-card tap-scale" bindtap="onWeatherTap">
      <text class="weather__icon">{{weather.icon}}</text>
      <view class="weather__info">
        <view class="weather__line1">{{weather.city}} · {{weather.temp}} {{weather.desc}}</view>
        <view class="weather__line2 text-sub">{{weather.suggestion}}</view>
      </view>
      <text class="weather__arrow text-assist">›</text>
    </view>

    <!-- C. 今日推荐搭配 -->
    <view class="outfit-card glass-card">
      <view class="outfit-card__head">
        <view class="outfit-card__tag">今日推荐</view>
        <view class="outfit-card__match">
          <text class="outfit-card__match-num">{{todayOutfit.match}}%</text>
          <text class="outfit-card__match-text">匹配</text>
        </view>
      </view>

      <!-- 服饰网格：左 2 格 + 右 3 格 -->
      <view class="outfit-card__grid">
        <view class="outfit-card__col outfit-card__col--left">
          <view class="outfit-slot outfit-slot--lg">
            <text class="outfit-slot__icon">{{todayOutfit.items[0].icon}}</text>
            <text class="outfit-slot__label text-sub">{{todayOutfit.items[0].name}}</text>
          </view>
          <view class="outfit-slot outfit-slot--md">
            <text class="outfit-slot__icon">{{todayOutfit.items[1].icon}}</text>
            <text class="outfit-slot__label text-sub">{{todayOutfit.items[1].name}}</text>
          </view>
        </view>
        <view class="outfit-card__col outfit-card__col--right">
          <view class="outfit-slot outfit-slot--lg">
            <text class="outfit-slot__icon">{{todayOutfit.items[2].icon}}</text>
            <text class="outfit-slot__label text-sub">{{todayOutfit.items[2].name}}</text>
          </view>
          <view class="outfit-slot outfit-slot--sm">
            <text class="outfit-slot__icon">{{todayOutfit.items[3].icon}}</text>
          </view>
          <view class="outfit-slot outfit-slot--sm">
            <text class="outfit-slot__icon">{{todayOutfit.items[4].icon}}</text>
          </view>
        </view>
      </view>

      <view class="outfit-card__info">
        <view class="outfit-card__title">{{todayOutfit.title}}</view>
      </view>

      <view class="outfit-card__chips">
        <view class="chip" wx:for="{{todayOutfit.chips}}" wx:key="*this">{{item}}</view>
      </view>
    </view>

    <!-- D. 反馈互动条 -->
    <view class="feedback glass-card">
      <view class="fb-btn tap-scale {{liked ? 'is-liked' : ''}}" bindtap="onLike">
        <view class="fb-btn__circle"><text class="fb-btn__icon">👍</text></view>
        <text class="fb-btn__label">喜欢</text>
      </view>
      <view class="fb-btn tap-scale" bindtap="onDislike">
        <view class="fb-btn__circle"><text class="fb-btn__icon">👎</text></view>
        <text class="fb-btn__label">换风格</text>
      </view>
      <view class="fb-btn tap-scale {{saved ? 'is-saved' : ''}}" bindtap="onSave">
        <view class="fb-btn__circle"><text class="fb-btn__icon">{{saved ? '⭐' : '☆'}}</text></view>
        <text class="fb-btn__label">{{saved ? '已收藏' : '收藏'}}</text>
      </view>
      <view class="fb-btn fb-btn--primary tap-scale" bindtap="onRegenerate">
        <view class="fb-btn__circle fb-btn__circle--primary"><text class="fb-btn__icon">🔄</text></view>
        <text class="fb-btn__label text-primary">再来一套</text>
      </view>
    </view>

    <!-- E. 风格标签横滑 -->
    <view class="section-head">
      <view class="section-head__title">风格偏好</view>
    </view>
    <scroll-view
      class="style-scroll"
      scroll-x="{{true}}"
      enhanced="{{true}}"
      show-scrollbar="{{false}}"
    >
      <view
        wx:for="{{styles}}"
        wx:key="id"
        class="style-chip tap-scale {{item.active ? 'is-active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onStyleTap"
      >{{item.name}}</view>
    </scroll-view>

    <!-- F. 更多推荐 -->
    <view class="section-head">
      <view class="section-head__title">更多推荐</view>
      <view class="section-head__more text-assist">查看全部 ›</view>
    </view>
    <view class="picks-grid">
      <view
        class="pick-card tap-scale"
        wx:for="{{morePicks}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onPickTap"
      >
        <view class="pick-card__cover" style="background: {{item.cover}};">
          <text class="pick-card__emoji">{{item.emoji}}</text>
          <view
            class="pick-card__heart {{item.liked ? 'is-liked' : ''}}"
            data-id="{{item.id}}"
            catchtap="onPickLike"
          >
            <text>{{item.liked ? '❤️' : '🤍'}}</text>
          </view>
        </view>
        <view class="pick-card__info">
          <view class="pick-card__title">{{item.title}}</view>
          <view class="pick-card__match text-primary">{{item.match}}% 匹配</view>
        </view>
      </view>
    </view>

    <!-- G. 最近搭配 -->
    <view class="section-head">
      <view class="section-head__title">最近搭配</view>
      <view class="section-head__more text-assist">全部历史 ›</view>
    </view>
    <scroll-view
      class="recent-scroll"
      scroll-x="{{true}}"
      enhanced="{{true}}"
      show-scrollbar="{{false}}"
    >
      <view class="recent-card tap-scale" wx:for="{{recent}}" wx:key="id">
        <view class="recent-card__cover" style="background: {{item.cover}};">
          <text class="recent-card__emoji">{{item.emoji}}</text>
        </view>
        <view class="recent-card__info">
          <view class="recent-card__date">{{item.date}}</view>
          <view class="recent-card__title">{{item.title}}</view>
        </view>
      </view>
    </scroll-view>

    <view class="safe-bottom"></view>
  </scroll-view>
</view>
