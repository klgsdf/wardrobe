/* custom-tab-bar/index.wxss - 参考图风格：扁平细线图标 + 中央 Add 细线按钮 */

/* ============ 色板变量：浅色（默认） ============ */
.tabbar {
  --tb-stroke:      #C8C0BC;                    /* 未选中图标线条（暖灰） */
  --tb-active:      #D4A373;                    /* 激活色：焦糖 */
  --tb-label-sub:   #C8C0BC;                    /* 未选中 label */
  --tb-surface:     #FFFFFF;                    /* 底部背景 */
  --tb-border:      rgba(140, 130, 120, 0.10);   /* 顶部细线 */
  --tb-add-stroke:  #D4A373;
  --tb-add-text:    #D4A373;
}

/* ============ 色板变量：深色 ============ */
.tabbar.theme-dark {
  --tb-stroke:      #6A6460;
  --tb-active:      #C8A880;
  --tb-label-sub:   #6A6460;
  --tb-surface:     #2E2C2A;
  --tb-border:      rgba(255, 255, 255, 0.06);
  --tb-add-stroke:  #C8A880;
  --tb-add-text:    #C8A880;
}

/* ============ 容器 ============ */
.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: calc(120rpx + env(safe-area-inset-bottom));
  z-index: 999;
  pointer-events: none;
}

/* ============ 底部背景条（带顶部细线） ============ */
.tabbar__bg {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  top: 0;
  background: var(--tb-surface);
  border-top: 1rpx solid var(--tb-border);
  pointer-events: auto;
}

/* ============ 内层 4 tab + 占位 ============ */
.tabbar__inner {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: env(safe-area-inset-bottom);
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 20rpx;
  pointer-events: auto;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 4rpx 0;
  min-width: 0;
  height: 100%;
}

.tab-item--placeholder { visibility: hidden; }

.tab-item__icon {
  width: 44rpx;
  height: 44rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ============ 统一 label ============ */
.tabbar-label {
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", "HarmonyOS Sans SC", sans-serif;
  font-size: 20rpx;
  font-weight: 400;
  letter-spacing: 0.2rpx;
  line-height: 1;
  color: var(--tb-label-sub);
  transition: color 0.2s ease;
}

.tab-item.is-active .tabbar-label {
  color: var(--tb-active);
  font-weight: 600;
}

/* ============ home 小屋（细线风格） ============ */
.ic-home { position: relative; width: 40rpx; height: 40rpx; }
.ic-home__roof {
  position: absolute; top: 0; left: 50%;
  width: 28rpx; height: 14rpx;
  border: 2rpx solid var(--tb-stroke); border-bottom: none;
  border-radius: 14rpx 14rpx 0 0;
  transform: translateX(-50%); box-sizing: border-box;
}
.ic-home__wall {
  position: absolute; bottom: 0; left: 50%;
  width: 32rpx; height: 24rpx;
  border: 2rpx solid var(--tb-stroke); border-top: none;
  transform: translateX(-50%); box-sizing: border-box;
}
.ic-home__door {
  position: absolute; bottom: 0; left: 50%;
  width: 8rpx; height: 12rpx;
  border: 2rpx solid var(--tb-stroke); border-bottom: none;
  border-radius: 4rpx 4rpx 0 0;
  transform: translateX(-50%); box-sizing: border-box;
}
.tab-item.is-active .ic-home__roof,
.tab-item.is-active .ic-home__wall,
.tab-item.is-active .ic-home__door { border-color: var(--tb-active); }

/* ============ 衣柜（开放式衣架风格） ============ */
.ic-closet { position: relative; width: 40rpx; height: 40rpx; }
.ic-closet__frame {
  position: absolute; top: 0; left: 50%;
  width: 30rpx; height: 20rpx;
  border: 2rpx solid var(--tb-stroke); border-bottom: none;
  border-radius: 4rpx 4rpx 0 0;
  transform: translateX(-50%); box-sizing: border-box;
}
.ic-closet__hanger {
  position: absolute; top: 6rpx; left: 50%;
  width: 10rpx; height: 6rpx;
  border: 2rpx solid var(--tb-stroke); border-top: none;
  border-radius: 0 0 5rpx 5rpx;
  transform: translateX(-50%); box-sizing: border-box;
}
.ic-closet__bar {
  position: absolute; top: 18rpx; left: 50%;
  width: 26rpx; height: 2rpx;
  background: var(--tb-stroke);
  transform: translateX(-50%);
}
.ic-closet__leg-l,
.ic-closet__leg-r {
  position: absolute; bottom: 0;
  width: 2rpx; height: 20rpx;
  background: var(--tb-stroke);
}
.ic-closet__leg-l { left: 6rpx; }
.ic-closet__leg-r { right: 6rpx; }
.tab-item.is-active .ic-closet__frame,
.tab-item.is-active .ic-closet__hanger { border-color: var(--tb-active); }
.tab-item.is-active .ic-closet__bar,
.tab-item.is-active .ic-closet__leg-l,
.tab-item.is-active .ic-closet__leg-r { background: var(--tb-active); }

/* ============ T恤（衣服） ============ */
.ic-tee { position: relative; width: 40rpx; height: 40rpx; }
.ic-tee__body {
  position: absolute; bottom: 0; left: 50%;
  width: 26rpx; height: 24rpx;
  border: 2rpx solid var(--tb-stroke); border-top: none;
  border-radius: 0 0 4rpx 4rpx;
  transform: translateX(-50%); box-sizing: border-box;
}
.ic-tee__sleeve-l,
.ic-tee__sleeve-r {
  position: absolute; top: 4rpx;
  width: 10rpx; height: 14rpx;
  border: 2rpx solid var(--tb-stroke);
  box-sizing: border-box;
}
.ic-tee__sleeve-l { left: 1rpx;  border-right: none; border-bottom: none; border-radius: 3rpx 0 0 0; }
.ic-tee__sleeve-r { right: 1rpx; border-left:  none; border-bottom: none; border-radius: 0 3rpx 0 0; }
.ic-tee__neck {
  position: absolute; top: 0; left: 50%;
  width: 12rpx; height: 5rpx;
  border: 2rpx solid var(--tb-stroke); border-top: none;
  border-radius: 0 0 6rpx 6rpx;
  transform: translateX(-50%); box-sizing: border-box;
}
.tab-item.is-active .ic-tee__body,
.tab-item.is-active .ic-tee__sleeve-l,
.tab-item.is-active .ic-tee__sleeve-r,
.tab-item.is-active .ic-tee__neck { border-color: var(--tb-active); }

/* ============ 头像（个人） ============ */
.ic-person { position: relative; width: 36rpx; height: 40rpx; }
.ic-person__head {
  position: absolute; top: 0; left: 50%;
  width: 18rpx; height: 18rpx;
  border: 2rpx solid var(--tb-stroke);
  border-radius: 50%;
  transform: translateX(-50%); box-sizing: border-box;
}
.ic-person__body {
  position: absolute; bottom: 0; left: 50%;
  width: 32rpx; height: 20rpx;
  border: 2rpx solid var(--tb-stroke); border-bottom: none;
  border-radius: 16rpx 16rpx 0 0;
  transform: translateX(-50%); box-sizing: border-box;
}
.tab-item.is-active .ic-person__head,
.tab-item.is-active .ic-person__body { border-color: var(--tb-active); }

/* ============ 中央 Add 细线按钮 ============ */
.tabbar__add {
  position: absolute;
  left: 50%;
  bottom: calc(44rpx + env(safe-area-inset-bottom));
  transform: translateX(-50%);
  pointer-events: auto;
}

.tabbar__add-ring {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  background: var(--tb-surface);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 2rpx solid var(--tb-add-stroke);
}

.tabbar__add-text {
  color: var(--tb-add-text);
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.3rpx;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", sans-serif;
}

/* ============ 选中指示条 ============ */
.tabbar__indicator {
  position: absolute;
  bottom: calc(4rpx + env(safe-area-inset-bottom));
  left: 0;
  width: 25%;
  height: 3rpx;
  background: var(--tb-active);
  border-radius: 2rpx;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ============ 点击反馈 ============ */
.tap-scale { transition: transform 0.15s ease; }
.tap-scale:active { transform: scale(0.94); }
.tabbar__add.tap-scale:active { transform: translateX(-50%) scale(0.94); }
