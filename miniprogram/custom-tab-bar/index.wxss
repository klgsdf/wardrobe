/* custom-tab-bar/index.wxss - 手绘线条风 tabBar（变量化 · 深浅主题统一） */

/* ============ 色板变量：浅色（默认） ============ */
.tabbar {
  --tb-stroke:      #4A403A;                    /* 图标线条 + 激活 label + Add 线 */
  --tb-label-sub:   #9C8C84;                    /* 未选中 label */
  --tb-surface:     #FFFDF5;                    /* Add 圆环背景 / 底条背景 */
  --tb-border:      rgba(156, 140, 132, 0.20);
  --tb-shadow-bar:  0 -8rpx 24rpx -6rpx rgba(74, 64, 58, 0.08);
  --tb-shadow-add:  0 8rpx 20rpx -4rpx rgba(74, 64, 58, 0.15);
}

/* ============ 色板变量：深色（暖棕咖啡） ============ */
.tabbar.theme-dark {
  --tb-stroke:      #F5E6D3;
  --tb-label-sub:   #8A7A6A;
  --tb-surface:     #2E241D;
  --tb-border:      rgba(230, 184, 136, 0.22);
  --tb-shadow-bar:  0 -8rpx 24rpx -6rpx rgba(0, 0, 0, 0.40);
  --tb-shadow-add:  0 10rpx 24rpx -4rpx rgba(0, 0, 0, 0.55);
}

/* ============ 容器 ============ */
.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: calc(120rpx + env(safe-area-inset-bottom));
  z-index: 999;
  pointer-events: none;
}

.tabbar__bg {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  top: 30rpx;
  background: var(--tb-surface);
  border-top: 2rpx solid var(--tb-border);
  box-shadow: var(--tb-shadow-bar);
  pointer-events: auto;
  transition: background 0.4s ease;
}

.tabbar__inner {
  position: absolute;
  left: 0;
  right: 0;
  top: 30rpx;
  bottom: env(safe-area-inset-bottom);
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 16rpx;
  pointer-events: auto;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 8rpx 0;
  min-width: 0;
}

.tab-item--placeholder { visibility: hidden; }

.tab-item__icon {
  width: 52rpx;
  height: 52rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.70;
  transition: opacity 0.2s ease;
}

.tab-item.is-active .tab-item__icon { opacity: 1; }

/* ============ 统一 label 样式（三处共用） ============ */
.tabbar-label {
  font-family: "Inter", "HarmonyOS Sans SC", "PingFang SC", -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  line-height: 1;
  color: var(--tb-label-sub);
  transition: color 0.2s ease;
}

.tab-item.is-active .tabbar-label {
  color: var(--tb-stroke);
  font-weight: 600;
}

/* Add 按钮 label 与激活态同级（主色 + 加粗） */
.tabbar-label--add {
  color: var(--tb-stroke);
  font-weight: 600;
  margin-top: 8rpx;
}

/* ========== 线条 home 小屋 ========== */
.ic-home { position: relative; width: 48rpx; height: 48rpx; }
.ic-home__roof {
  position: absolute; top: 4rpx; left: 50%;
  width: 40rpx; height: 24rpx;
  border: 3rpx solid var(--tb-stroke); border-bottom: none;
  border-radius: 24rpx 24rpx 0 0;
  transform: translateX(-50%); box-sizing: border-box;
}
.ic-home__body {
  position: absolute; bottom: 4rpx; left: 50%;
  width: 40rpx; height: 22rpx;
  border: 3rpx solid var(--tb-stroke); border-top: none;
  transform: translateX(-50%); box-sizing: border-box;
}
.ic-home__door {
  position: absolute; bottom: 4rpx; left: 50%;
  width: 12rpx; height: 16rpx;
  border: 3rpx solid var(--tb-stroke); border-bottom: none;
  border-radius: 6rpx 6rpx 0 0;
  transform: translateX(-50%); box-sizing: border-box;
}

/* ========== 线条衣柜图标 ========== */
.ic-closet { position: relative; width: 44rpx; height: 48rpx; }
.ic-closet__box {
  position: absolute; inset: 0;
  border: 3rpx solid var(--tb-stroke);
  border-radius: 6rpx; box-sizing: border-box;
}
.ic-closet__split {
  position: absolute; top: 0; bottom: 0; left: 50%;
  width: 3rpx; background: var(--tb-stroke);
  transform: translateX(-50%);
}
.ic-closet__handle {
  position: absolute; top: 40%;
  width: 4rpx; height: 12rpx;
  background: var(--tb-stroke);
  border-radius: 2rpx;
}
.ic-closet__handle--l { right: 52%; }
.ic-closet__handle--r { left: 52%; }

/* ========== 线条 T 恤 ========== */
.ic-tee { position: relative; width: 50rpx; height: 48rpx; }
.ic-tee__body {
  position: absolute; bottom: 0; left: 50%;
  width: 32rpx; height: 30rpx;
  border: 3rpx solid var(--tb-stroke); border-top: none;
  border-radius: 0 0 6rpx 6rpx;
  transform: translateX(-50%); box-sizing: border-box;
}
.ic-tee__shoulder {
  position: absolute; top: 4rpx;
  width: 12rpx; height: 18rpx;
  border: 3rpx solid var(--tb-stroke);
  box-sizing: border-box;
}
.ic-tee__shoulder--l { left: 0;  border-right: none; border-bottom: none; border-radius: 4rpx 0 0 0; }
.ic-tee__shoulder--r { right: 0; border-left:  none; border-bottom: none; border-radius: 0 4rpx 0 0; }
.ic-tee__neck {
  position: absolute; top: 0; left: 50%;
  width: 14rpx; height: 6rpx;
  border: 3rpx solid var(--tb-stroke); border-top: none;
  border-radius: 0 0 7rpx 7rpx;
  transform: translateX(-50%); box-sizing: border-box;
}

/* ========== 线条头像 ========== */
.ic-person { position: relative; width: 40rpx; height: 48rpx; }
.ic-person__head {
  position: absolute; top: 0; left: 50%;
  width: 20rpx; height: 20rpx;
  border: 3rpx solid var(--tb-stroke);
  border-radius: 50%;
  transform: translateX(-50%); box-sizing: border-box;
}
.ic-person__body {
  position: absolute; bottom: 0; left: 50%;
  width: 36rpx; height: 22rpx;
  border: 3rpx solid var(--tb-stroke); border-bottom: none;
  border-radius: 18rpx 18rpx 0 0;
  transform: translateX(-50%); box-sizing: border-box;
}

/* ========== 中间 Add 凸起按钮 ========== */
.tabbar__add {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  pointer-events: auto;
}

.tabbar__add-ring {
  position: relative;
  width: 90rpx;
  height: 90rpx;
  border: 3rpx solid var(--tb-stroke);
  background: var(--tb-surface);
  border-radius: 50%;
  box-shadow: var(--tb-shadow-add);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  transition: background 0.4s ease, box-shadow 0.4s ease;
}

.tabbar__add-plus-h,
.tabbar__add-plus-v {
  position: absolute; top: 50%; left: 50%;
  background: var(--tb-stroke);
  border-radius: 2rpx;
  transform: translate(-50%, -50%);
}
.tabbar__add-plus-h { width: 36rpx; height: 3rpx; }
.tabbar__add-plus-v { width: 3rpx;  height: 36rpx; }

/* 点击反馈 */
.tap-scale:active { transform: scale(0.94); transition: transform 0.12s ease; }
.tabbar__add.tap-scale:active { transform: translateX(-50%) scale(0.94); }
